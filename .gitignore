# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
.nuxt/
.output/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
spec/examples.txt

# Misc
.cache/
tmp/

# Ignore key files for decrypting credentials and more.
/config/*.key

# Rails assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Compiled assets (generated by assets:precompile)
# These are rebuilt during deployment and should not be in Git
/public/assets
# Exception: Keep static files that are not compiled
!/public/assets/.keep

# Node modules
/node_modules

# ========================================
# DATABASE FILES - SECURITY CRITICAL
# ========================================
# NEVER commit production or development databases!
# These contain sensitive user data and should be backed up separately.

# SQLite databases (all environments)
*.sqlite3
*.sqlite3-*
*.db

# Specific database paths
/db/*.sqlite3
/db/*.sqlite3-*
/storage/*.sqlite3
/storage/*.sqlite3-*

# SQLite WAL files (Write-Ahead Logging)
*.sqlite3-wal
*.sqlite3-shm
*.sqlite3-journal

# ========================================
# STORAGE & UPLOADS - SECURITY CRITICAL
# ========================================
# Active Storage uploads (images, audio, files)
# Keep .keep files for empty directory structure
/storage/*
!/storage/.keep

# Temporary audio files
/tmp/audio/*
!/tmp/audio/.keep

# ========================================
# LOGS & TEMPORARY FILES
# ========================================
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep
!/tmp/audio
!/tmp/pids
!/tmp/cache
!/tmp/sockets

# Docker volumes (if mounted locally)
/vendor/bundle
