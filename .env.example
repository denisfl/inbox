# Rails Core
RAILS_ENV=development
SECRET_KEY_BASE=your_secret_key_base_here_generate_with_rails_secret
RAILS_LOG_TO_STDOUT=true

# Database
DATABASE_URL=sqlite3:db/development.sqlite3
DATABASE_TIMEOUT=5000

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_BOT_NAME=your_bot_name_here
TELEGRAM_ALLOWED_USER_ID=YOUR_TELEGRAM_USER_ID
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# Authentication
API_TOKEN=your_random_secure_token_here
API_TOKEN_ROTATION_DAYS=90

# Audio Transcription (Parakeet v3 via onnx-asr)
# Use http://localhost:5001 for local dev (bin/dev), http://transcriber:5000 in Docker
# Port 5001 because macOS AirPlay uses 5000
TRANSCRIBER_URL=http://transcriber:5000
# TRANSCRIBER_LANGUAGE=ru  # Uncomment to force language; default: auto-detect (supports 25 languages)

# Service Timeouts (seconds)
# TRANSCRIBER_TIMEOUT=600     # Default: 600s — transcription can take long for large audio files
# TELEGRAM_TIMEOUT=30         # Default: 30s — Telegram API and file downloads
# GOOGLE_CALENDAR_TIMEOUT=15  # Default: 15s — Google Calendar API calls

# Sidekiq
SIDEKIQ_CONCURRENCY=2
SIDEKIQ_TIMEOUT=600

# Backup
# Storage type: "local" (default) or "s3" (S3-compatible)
# DEPRECATED: Use Settings > Storage in the web UI instead.
# These vars are kept for backward compatibility during transition.
BACKUP_STORAGE_TYPE=local
BACKUP_RETENTION_DAYS=30
# Local backup path (used when BACKUP_STORAGE_TYPE=local)
BACKUP_LOCAL_PATH=/app/storage/backups
# S3-compatible storage (used when BACKUP_STORAGE_TYPE=s3)
# BACKUP_S3_BUCKET=your-bucket-name
# BACKUP_S3_ACCESS_KEY=your-access-key
# BACKUP_S3_SECRET_KEY=your-secret-key
# BACKUP_S3_REGION=us-east-1
# BACKUP_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com  # Optional: for Backblaze B2, MinIO, etc.

# Cloud Storage OAuth (configure providers via Settings > Storage in the web UI)
# DROPBOX_CLIENT_ID=your-dropbox-app-key
# DROPBOX_CLIENT_SECRET=your-dropbox-app-secret
# GOOGLE_DRIVE_CLIENT_ID=your-google-drive-client-id
# GOOGLE_DRIVE_CLIENT_SECRET=your-google-drive-client-secret
# ONEDRIVE_CLIENT_ID=your-onedrive-app-client-id
# ONEDRIVE_CLIENT_SECRET=your-onedrive-client-secret

# Logging
LOG_LEVEL=info

# Version Tracking (auto-set during Docker build)
# GIT_SHA=abc1234

# Development only
WEB_CONCURRENCY=1
RAILS_MAX_THREADS=5
