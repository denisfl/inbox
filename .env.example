# Rails Core
RAILS_ENV=development
SECRET_KEY_BASE=your_secret_key_base_here_generate_with_rails_secret
RAILS_LOG_TO_STDOUT=true

# Database
DATABASE_URL=sqlite3:db/development.sqlite3
DATABASE_TIMEOUT=5000

# Redis
REDIS_URL=redis://redis:6379/0

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_BOT_NAME=your_bot_name_here
TELEGRAM_ALLOWED_USER_ID=YOUR_TELEGRAM_USER_ID
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook

# Authentication
API_TOKEN=your_random_secure_token_here
API_TOKEN_ROTATION_DAYS=90

# Audio Transcription (Parakeet v3 via onnx-asr)
# Use http://localhost:5001 for local dev (bin/dev), http://transcriber:5000 in Docker
# Port 5001 because macOS AirPlay uses 5000
TRANSCRIBER_URL=http://transcriber:5000
# TRANSCRIBER_LANGUAGE=ru  # Uncomment to force language; default: auto-detect (supports 25 languages)

# Sidekiq
SIDEKIQ_CONCURRENCY=2
SIDEKIQ_TIMEOUT=600

# Backup
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
BACKUP_ENCRYPTION_KEY=your_gpg_key_id_optional
CLOUD_BACKUP_ENABLED=false
CLOUD_BACKUP_PROVIDER=gdrive

# Logging
LOG_LEVEL=info

# Version Tracking (auto-set during Docker build)
# GIT_SHA=abc1234

# Development only
WEB_CONCURRENCY=1
RAILS_MAX_THREADS=5
