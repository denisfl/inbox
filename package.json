{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/*.* --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css": "pnpm exec tailwindcss -i app/assets/stylesheets/application.tailwind.css -o app/assets/builds/application.css --minify"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.12",
    "highlight.js": "^11.11.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "tailwindcss": "^3.4.0"
  }
}
