#!/usr/bin/env sh

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

# Default to port 3000 if not specified
export PORT="${PORT:-3000}"

# Load .env file if it exists (foreman natively supports this)
if [ -f .env ]; then
  ENV_FILE=".env"
else
  ENV_FILE="/dev/null"
fi

exec foreman start -f Procfile.dev --env "$ENV_FILE" "$@"
