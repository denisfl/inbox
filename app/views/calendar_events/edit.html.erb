<% content_for :title, "Edit Event — Inbox" %>

<div class="event-form-page">
  <div class="event-form-container">
    <header class="event-form-header">
      <%= link_to calendar_path(date: @event.starts_at&.to_date), class: "back-link" do %>
        <%= heroicon(:arrow_left, style: 'width: 16px; height: 16px;') %>
        Calendar
      <% end %>
      <h1 class="event-form-title">Edit Event</h1>
    </header>

    <%= render "form", event: @event, url: calendar_event_path(@event), method: :patch, submit_label: "Update Event" %>
  </div>
</div>

<style>
  .event-form-page {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-lg);
  }

  .event-form-container {
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
  }

  .event-form-header {
    margin-bottom: var(--spacing-lg);
  }

  .event-form-title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin: var(--spacing-sm) 0 0;
  }

  .event-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .event-form-errors {
    background: color-mix(in srgb, var(--color-danger) 8%, var(--color-bg-primary));
    border: 1px solid color-mix(in srgb, var(--color-danger) 30%, var(--color-border));
    border-radius: var(--radius-base);
    padding: var(--spacing-md);
    color: var(--color-danger);
    font-size: var(--text-sm);
  }
  .event-form-errors ul { margin: var(--spacing-xs) 0 0; padding-left: var(--spacing-md); }

  .event-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .event-field--inline {
    flex-direction: row;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .event-field-label {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-secondary);
  }

  .event-field-label--inline {
    margin: 0;
    cursor: pointer;
  }

  .event-field-group {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
  }

  .event-checkbox {
    width: 18px;
    height: 18px;
    accent-color: var(--color-primary);
    cursor: pointer;
  }

  /* Color picker */
  .event-color-picker {
    display: flex;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .event-color-swatch {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }

  .event-color-swatch:hover {
    transform: scale(1.15);
  }

  .event-color-radio {
    display: none;
  }

  .event-color-check {
    display: none;
    color: white;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .event-color-radio:checked + .event-color-check {
    display: block;
  }

  .event-color-radio:checked ~ .event-color-check {
    display: block;
  }

  .event-color-swatch:has(.event-color-radio:checked) {
    border-color: var(--color-text-primary);
    transform: scale(1.15);
  }

  /* Actions */
  .event-form-actions {
    display: flex;
    gap: var(--spacing-sm);
    padding-top: var(--spacing-sm);
  }

  @media (max-width: 768px) {
    .event-form-page { padding: var(--spacing-md); }
    .event-field-group { grid-template-columns: 1fr; }
  }
</style>
