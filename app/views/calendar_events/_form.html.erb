<%= form_with model: event, url: url, method: method, class: "event-form",
      data: { controller: "calendar-event-form" } do |f| %>
  <% if event.errors.any? %>
    <div class="event-form-errors">
      <p><strong><%= pluralize(event.errors.count, "error") %></strong> prevented this event from being saved:</p>
      <ul>
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Title %>
  <div class="event-field">
    <%= f.label :title, class: "event-field-label" %>
    <%= f.text_field :title, class: "input", placeholder: "Event title", autofocus: true, required: true %>
  </div>

  <%# All day toggle %>
  <div class="event-field event-field--inline">
    <%= f.check_box :all_day, class: "event-checkbox", id: "event_all_day",
          data: { action: "change->calendar-event-form#toggleAllDay" } %>
    <%= f.label :all_day, "All-day event", class: "event-field-label event-field-label--inline" %>
  </div>

  <%# Date shortcuts %>
  <div class="date-shortcuts">
    <button type="button" class="date-shortcut"
            data-action="click->calendar-event-form#setToday">Today</button>
    <button type="button" class="date-shortcut"
            data-action="click->calendar-event-form#setTomorrow">Tomorrow</button>
    <button type="button" class="date-shortcut"
            data-action="click->calendar-event-form#setDaysAhead"
            data-days="3">+3 days</button>
    <button type="button" class="date-shortcut"
            data-action="click->calendar-event-form#setDaysAhead"
            data-days="7">+7 days</button>
  </div>

  <%# Date / time fields %>
  <div class="event-field-group">
    <div class="event-field">
      <%= f.label :starts_at_date, "Start date", class: "event-field-label" %>
      <%= f.date_field :starts_at_date, class: "input", required: true,
            value: event.starts_at&.to_date %>
    </div>
    <div class="event-field" data-time-field>
      <%= f.label :starts_at_time, "Start time", class: "event-field-label" %>
      <div class="time-combobox" data-controller="time-combobox">
        <input type="text"
               class="input time-combobox__input"
               placeholder="9:00 AM"
               autocomplete="off"
               value="<%= event.starts_at&.strftime("%-I:%M %p") %>"
               data-time-combobox-target="input"
               data-action="focus->time-combobox#onFocus
                            blur->time-combobox#onBlur
                            input->time-combobox#onInput
                            keydown->time-combobox#onKeydown">
        <input type="hidden"
               name="calendar_event[starts_at_time]"
               value="<%= event.starts_at&.strftime("%H:%M") %>"
               data-time-combobox-target="hidden">
        <div class="time-combobox__dropdown" data-time-combobox-target="dropdown"></div>
      </div>
    </div>
  </div>
  <div class="event-field-group">
    <div class="event-field">
      <%= f.label :ends_at_date, "End date", class: "event-field-label" %>
      <%= f.date_field :ends_at_date, class: "input",
            value: event.ends_at&.to_date %>
    </div>
    <div class="event-field" data-time-field>
      <%= f.label :ends_at_time, "End time", class: "event-field-label" %>
      <div class="time-combobox" data-controller="time-combobox">
        <input type="text"
               class="input time-combobox__input"
               placeholder="10:00 AM"
               autocomplete="off"
               value="<%= event.ends_at&.strftime("%-I:%M %p") %>"
               data-time-combobox-target="input"
               data-action="focus->time-combobox#onFocus
                            blur->time-combobox#onBlur
                            input->time-combobox#onInput
                            keydown->time-combobox#onKeydown">
        <input type="hidden"
               name="calendar_event[ends_at_time]"
               value="<%= event.ends_at&.strftime("%H:%M") %>"
               data-time-combobox-target="hidden">
        <div class="time-combobox__dropdown" data-time-combobox-target="dropdown"></div>
      </div>
    </div>
  </div>

  <%# Duration presets %>
  <div class="duration-presets" data-calendar-event-form-target="durationRow" data-time-field>
    <span class="duration-label">Duration:</span>
    <button type="button" class="duration-btn" data-minutes="15"
            data-action="click->calendar-event-form#setDuration">15m</button>
    <button type="button" class="duration-btn" data-minutes="30"
            data-action="click->calendar-event-form#setDuration">30m</button>
    <button type="button" class="duration-btn" data-minutes="60"
            data-action="click->calendar-event-form#setDuration">1h</button>
    <button type="button" class="duration-btn" data-minutes="120"
            data-action="click->calendar-event-form#setDuration">2h</button>
  </div>

  <%# Description %>
  <div class="event-field">
    <%= f.label :description, "Description", class: "event-field-label" %>
    <%= f.rich_text_area :description %>
  </div>

  <%# Color %>
  <div class="event-field">
    <%= f.label :color, "Color", class: "event-field-label" %>
    <div class="event-color-picker">
      <% CalendarEvent::GOOGLE_COLOR_MAP.each do |id, hex| %>
        <label class="event-color-swatch" style="background: <%= hex %>;" title="Color <%= id %>">
          <%= f.radio_button :color, id, class: "event-color-radio" %>
          <span class="event-color-check">✓</span>
        </label>
      <% end %>
    </div>
  </div>

  <%# Tags (only for saved events) %>
  <% if event.persisted? %>
    <div class="event-field">
      <label class="event-field-label">Tags</label>
      <%= render "shared/tag_input", entity_type: "calendar_event", entity: event %>
    </div>
  <% end %>

  <%# Actions %>
  <div class="event-form-actions">
    <%= f.submit submit_label, class: "btn btn-primary" %>
    <%= link_to "Cancel", calendar_path, class: "btn btn-secondary" %>
  </div>
<% end %>
