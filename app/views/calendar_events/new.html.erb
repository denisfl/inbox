<% content_for :title, "New Event — Inbox" %>

<div class="event-form-page">
  <div class="event-form-container">
    <header class="event-form-header">
      <%= back_link(calendar_path, "Calendar") %>
      <h1 class="event-form-title">New Event</h1>
    </header>

    <%= render "form", event: @event, url: calendar_events_path, method: :post, submit_label: "Create Event" %>
  </div>
</div>

