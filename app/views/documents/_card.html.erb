<%
  # Determine document type and icons
  has_voice = document.blocks.any? { |b| b.block_type == 'file' && b.content.to_s.include?('voice') }
  has_photo = document.blocks.any? { |b| b.block_type == 'file' && (b.content.to_s.include?('image') || b.content.to_s.include?('photo')) }
  has_document_file = document.blocks.any? { |b| b.block_type == 'file' && !b.content.to_s.include?('voice') && !b.content.to_s.include?('image') }

  # Get first text block for preview
  preview_text = nil
  text_block = document.blocks.find { |b| b.block_type == 'text' }
  if text_block && text_block.content.present?
    begin
      content_data = text_block.content.is_a?(String) ? JSON.parse(text_block.content) : text_block.content
      raw_text = content_data['text'] || content_data[:text]
      preview_text = raw_text if raw_text.present? && raw_text != document.title
    rescue JSON::ParserError
      # Invalid JSON, skip preview
    end
  end
%>

<article class="document-card">
  <%# ── Header: badges + time ── %>
  <div class="card-header">
    <div class="card-badges">
      <% if document.source == 'telegram' %>
        <span class="source-badge source-badge--tg">Telegram</span>
      <% else %>
        <span class="source-badge">Manual</span>
      <% end %>

      <% if has_voice %>
        <span class="source-badge source-badge--voice">Voice</span>
      <% elsif has_photo %>
        <span class="source-badge source-badge--photo">Photo</span>
      <% elsif has_document_file %>
        <span class="source-badge source-badge--file">File</span>
      <% end %>
    </div>

    <time class="card-time" datetime="<%= document.updated_at.iso8601 %>"
          title="<%= document.updated_at.strftime('%B %d, %Y at %H:%M') %>">
      <%= time_ago_in_words(document.updated_at) %> ago
    </time>
  </div>

  <%# ── Title (clickable) ── %>
  <%= link_to edit_document_path(document), class: "card-link" do %>
    <h3 class="card-title"><%= document.title.truncate(80) %></h3>
  <% end %>

  <%# ── Preview text ── %>
  <% if preview_text %>
    <div class="card-preview"><%= preview_text.truncate(120) %></div>
  <% end %>

  <%# ── Footer: tags ── %>
  <% if document.tags.any? %>
    <div class="card-footer">
      <% document.tags.limit(3).each do |tag| %>
        <%= link_to root_path(tag: tag.name), class: "card-tag" do %>
          #<%= tag.name %>
        <% end %>
      <% end %>
      <% if document.tags.count > 3 %>
        <span class="card-tag">+<%= document.tags.count - 3 %></span>
      <% end %>
    </div>
  <% end %>

  <%# ── Hover actions ── %>
  <div class="card-hover-actions">
    <%= button_to document_path(document), method: :delete,
          class: "card-hover-btn card-hover-btn--delete",
          title: "Delete note",
          form: { data: { turbo_confirm: "Delete \"#{j document.title.truncate(40)}\"? This cannot be undone." } } do %>
      <%= heroicon(:trash, style: 'width: 1rem; height: 1rem;') %>
    <% end %>
  </div>
</article>

<style>
/* ── Card ── */
.document-card {
  position: relative;
  background-color: var(--color-bg-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.document-card:hover {
  border-color: var(--color-text-tertiary);
  box-shadow: var(--shadow-sm);
}

/* ── Header ── */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
}
.card-badges {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  flex-wrap: wrap;
}
.card-time {
  font-size: var(--text-xs);
  color: var(--color-text-tertiary);
  white-space: nowrap;
}

/* ── Source badges ── */
.source-badge {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: var(--font-semibold);
  letter-spacing: 0.02em;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-full);
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
}
.source-badge--tg  { background: color-mix(in srgb, var(--color-primary) 12%, var(--color-bg-primary)); color: var(--color-primary); }
.source-badge--voice { background: color-mix(in srgb, var(--color-accent) 20%, var(--color-bg-primary)); color: color-mix(in srgb, var(--color-accent) 70%, var(--color-text-primary)); }
.source-badge--photo { background: color-mix(in srgb, var(--color-secondary) 15%, var(--color-bg-primary)); color: var(--color-secondary); }
.source-badge--file  { background: var(--color-bg-tertiary); color: var(--color-text-secondary); }

/* ── Title ── */
.card-link {
  text-decoration: none;
  color: inherit;
  min-height: 44px;
  display: flex;
  align-items: center;
}
.card-link:hover .card-title { color: var(--color-primary); }
.card-title {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  color: var(--color-text-primary);
  margin: 0;
  line-height: 1.35;
}

/* ── Preview ── */
.card-preview {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── Footer / tags ── */
.card-footer {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  flex-wrap: wrap;
  margin-top: auto;
  padding-top: var(--spacing-sm);
}
.card-tag {
  font-size: var(--text-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-secondary);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--radius-sm);
  text-decoration: none;
  transition: background var(--transition-fast);
}
.card-tag:hover { background: var(--color-bg-hover); }

/* ── Hover actions ── */
.card-hover-actions {
  position: absolute;
  top: var(--spacing-sm);
  right: var(--spacing-sm);
  display: flex;
  gap: var(--spacing-xs);
  opacity: 0;
  transition: opacity var(--transition-fast);
}
.document-card:hover .card-hover-actions { opacity: 1; }

.card-hover-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-bg-primary);
  color: var(--color-text-secondary);
  cursor: pointer;
  transition: all var(--transition-fast);
}
.card-hover-btn:hover {
  background: var(--color-bg-secondary);
  color: var(--color-text-primary);
}
.card-hover-btn--delete:hover {
  color: var(--color-danger);
  border-color: color-mix(in srgb, var(--color-danger) 25%, var(--color-border));
  background: color-mix(in srgb, var(--color-danger) 6%, var(--color-bg-primary));
}

/* ── Mobile: always show actions ── */
@media (max-width: 768px) {
  .card-hover-actions { opacity: 1; }
  .card-title { font-size: var(--text-base); }
  .card-preview { -webkit-line-clamp: 1; }
}
</style>
