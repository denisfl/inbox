<% content_for :title, "#{@document.title} - Inbox" %>

<div class="simple-editor-container">
  <header class="simple-editor-header">
    <div class="simple-editor-header-left">
      <%= back_link(documents_path, "Back") %>

      <nav class="simple-editor-mode-toggle">
        <%= link_to edit_document_path(@document) do %>
          <%= heroicon(:pencil, style: 'width: 12px; height: 12px;') %> Edit
        <% end %>
        <%= link_to document_path(@document), class: "active" do %>
          <%= heroicon(:eye, style: 'width: 12px; height: 12px;') %> Preview
        <% end %>
      </nav>
      <%= render "documents/status_badge", document: @document %>
    </div>
    <div class="simple-editor-header-right">
    </div>
  </header>

  <div class="simple-editor-title-wrapper">
    <h1 class="simple-editor-title"><%= @document.title %></h1>
  </div>

  <% if @document.tags.any? %>
    <div class="simple-editor-tags">
      <% @document.tags.each do |tag| %>
        <%= link_to tag_path(tag.name), class: "card-tag" do %>
          <%= render "shared/tag", tag: tag %>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <main class="simple-editor-body">
    <% if @document.body.present? %>
      <div class="lexxy-content">
        <%= render_wiki_links(@document.body.to_s) %>
      </div>
    <% end %>

    <%= render "documents/connected_notes",
          links: @document.linked_documents,
          backlinks: @document.linking_documents %>
  </main>
</div>
