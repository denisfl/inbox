<% content_for :title, "#{@document.title} - Inbox" %>
<% content_for :head do %>
  <meta name="auth-token" content="<%= ENV['API_TOKEN'] || 'development_token' %>">
<% end %>

<%
  audio_mime_prefix = "audio/"
  audio_extensions  = %w[.ogg .mp3 .m4a .wav .opus .aac .flac .webm]

  text_block   = @blocks.find { |b| b.block_type == "text" }
  audio_blocks = @blocks.select do |b|
    b.block_type == "file" && b.file.attached? &&
      (b.file.content_type.to_s.start_with?(audio_mime_prefix) ||
       audio_extensions.any? { |ext| b.file.filename.to_s.end_with?(ext) })
  end

  image_blocks = @blocks.select { |b| b.block_type == "image" && b.image.attached? }
  file_blocks  = @blocks.select do |b|
    b.block_type == "file" && b.file.attached? &&
      !b.file.content_type.to_s.start_with?(audio_mime_prefix) &&
      audio_extensions.none? { |ext| b.file.filename.to_s.end_with?(ext) }
  end
%>

<div class="simple-editor-container"
     data-controller="simple-editor"
     data-simple-editor-document-id-value="<%= @document.id %>"
     data-simple-editor-block-id-value="<%= text_block&.id.to_i %>">

  <%# ── Header ────────────────────────────────────────────────────── %>
  <header class="simple-editor-header">
    <div class="simple-editor-header-left">
      <%= back_link(documents_path, "Back") %>
    </div>

    <div class="simple-editor-header-right">
      <span class="save-indicator" data-simple-editor-target="saveIndicator"></span>

      <%# Upload buttons %>
      <label class="simple-editor-upload-btn" title="Attach images">
        <%= heroicon :photo, width: 16, height: 16 %>
        <input type="file" accept="image/*" multiple class="hidden"
               data-simple-editor-target="imageInput"
               data-action="change->simple-editor#handleImageChange">
      </label>

      <label class="simple-editor-upload-btn" title="Attach files">
        <%= heroicon :paper_clip, width: 16, height: 16 %>
        <input type="file" multiple class="hidden"
               data-simple-editor-target="fileInput"
               data-action="change->simple-editor#handleFileChange">
      </label>

      <%# Preview / Edit toggle %>
      <button type="button"
              class="btn btn-sm simple-editor-preview-btn"
              data-simple-editor-target="previewToggleBtn"
              data-action="click->simple-editor#togglePreview">
        Preview
      </button>

      <%# Delete %>
      <%= button_to document_path(@document), method: :delete,
            class: "simple-editor-delete-btn",
            title: "Delete note",
            form: { data: { turbo_confirm: "Delete \"#{j @document.title.truncate(40)}\"? This will remove the note and all attached files. This cannot be undone." } } do %>
        <%= heroicon(:trash, style: 'width: 1rem; height: 1rem;') %>
      <% end %>
    </div>
  </header>

  <%# ── Title ─────────────────────────────────────────────────────── %>
  <div class="simple-editor-title-wrapper">
    <h1 class="simple-editor-title"
        contenteditable="true"
        data-simple-editor-target="title"
        data-action="blur->simple-editor#saveTitle"
        spellcheck="false"><%= @document.title %></h1>
  </div>

  <%# ── Editor body ────────────────────────────────────────────────── %>
  <main class="simple-editor-body">

    <%# ── Audio players (voice / audio blocks) ─────────────────────── %>
    <% if audio_blocks.any? %>
      <div class="simple-editor-audio-section">
        <% audio_blocks.each do |ab| %>
          <div class="simple-editor-attachment" data-block-id="<%= ab.id %>">
            <div class="simple-editor-audio-player">
              <audio controls preload="metadata"
                     src="<%= url_for(ab.file) %>"
                     style="width:100%">
                Your browser does not support audio playback.
              </audio>
              <div class="simple-editor-audio-filename">
                🎙 <%= ab.file.filename %>
              </div>
            </div>
            <button type="button" class="simple-editor-attachment-delete"
                    title="Remove audio"
                    data-action="click->simple-editor#deleteBlock"
                    data-block-id="<%= ab.id %>">
              <%= heroicon(:trash, style: "width:13px;height:13px") %>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Image blocks ──────────────────────────────────────────────── %>
    <% if image_blocks.any? %>
      <div class="simple-editor-images-section">
        <% image_blocks.each do |ib| %>
          <div class="simple-editor-attachment" data-block-id="<%= ib.id %>">
            <div class="simple-editor-image-wrapper">
              <%= image_tag url_for(ib.image), alt: ib.image.filename.to_s,
                    class: "simple-editor-image-preview" %>
              <div class="simple-editor-image-filename">
                📷 <%= ib.image.filename %> · <%= number_to_human_size(ib.image.byte_size) %>
              </div>
            </div>
            <button type="button" class="simple-editor-attachment-delete"
                    title="Remove image"
                    data-action="click->simple-editor#deleteBlock"
                    data-block-id="<%= ib.id %>">
              <%= heroicon(:trash, style: "width:13px;height:13px") %>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── File blocks (non-audio) ──────────────────────────────────── %>
    <% if file_blocks.any? %>
      <div class="simple-editor-files-section">
        <% file_blocks.each do |fb| %>
          <div class="simple-editor-attachment" data-block-id="<%= fb.id %>">
            <div class="simple-editor-file-info">
              <%= heroicon(:document, style: "width:16px;height:16px;color:var(--color-text-tertiary);flex-shrink:0") %>
              <a href="<%= url_for(fb.file) %>" target="_blank" class="simple-editor-file-link">
                <%= fb.file.filename %>
              </a>
              <span class="simple-editor-file-size"><%= number_to_human_size(fb.file.byte_size) %></span>
            </div>
            <button type="button" class="simple-editor-attachment-delete"
                    title="Remove file"
                    data-action="click->simple-editor#deleteBlock"
                    data-block-id="<%= fb.id %>">
              <%= heroicon(:trash, style: "width:13px;height:13px") %>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Edit mode (default): hidden when there is no text block and audio-only document %>
    <textarea class="simple-editor-textarea<%= ' hidden' if text_block.nil? && audio_blocks.any? %>"
              data-simple-editor-target="textarea"
              data-action="input->simple-editor#scheduleAutoSave"
              placeholder="Write in Markdown…"
              spellcheck="true"
              autocomplete="off"><%= text_block&.content_hash&.dig("text") %></textarea>

    <%# Preview mode (hidden by default) %>
    <div class="hidden markdown-preview simple-editor-preview"
         data-simple-editor-target="preview"></div>
  </main>
</div>

<style>
  .simple-editor-container {
    max-width: 800px;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg-primary);
  }

  /* Header */
  .simple-editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-sm) var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg-primary);
    z-index: var(--z-sticky);
  }

  .simple-editor-header-left,
  .simple-editor-header-right {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  /* Upload icon buttons */
  .simple-editor-upload-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-md);
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border);
    background: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    line-height: 1;
  }

  .simple-editor-upload-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  /* Preview toggle button */
  .simple-editor-preview-btn {
    font-size: var(--text-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
  }

  /* Delete button */
  .simple-editor-delete-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-md);
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border);
    background: none;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
    line-height: 1;
  }
  .simple-editor-delete-btn:hover {
    color: var(--color-danger);
    border-color: color-mix(in srgb, var(--color-danger) 25%, var(--color-border));
    background: color-mix(in srgb, var(--color-danger) 6%, var(--color-bg-primary));
  }

  /* Title */
  .simple-editor-title-wrapper {
    padding: var(--spacing-lg) var(--spacing-xl) 0;
  }

  .simple-editor-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    line-height: 1.25;
    margin: 0;
    padding: var(--spacing-xs) 0;
    outline: none;
    border-bottom: 2px solid transparent;
    word-break: break-word;
    color: var(--color-text-primary);
  }

  .simple-editor-title:focus {
    border-bottom-color: var(--color-primary);
  }

  /* Body */
  .simple-editor-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--spacing-md) var(--spacing-xl) var(--spacing-2xl);
  }

  /* Textarea */
  .simple-editor-textarea {
    flex: 1;
    width: 100%;
    min-height: calc(100vh - 200px);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-text-primary);
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    padding: 0;
    box-sizing: border-box;
  }

  .simple-editor-textarea::placeholder {
    color: var(--color-text-tertiary);
  }

  /* Preview pane */
  .simple-editor-preview {
    min-height: calc(100vh - 200px);
    line-height: 1.7;
    word-break: break-word;
  }

  /* Audio players */
  .simple-editor-audio-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .simple-editor-audio-player {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .simple-editor-audio-filename {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: var(--spacing-xs);
  }

  /* Attachments (common wrapper with delete button) */
  .simple-editor-attachment {
    position: relative;
  }

  .simple-editor-attachment-delete {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: var(--color-bg-secondary);
    color: var(--color-text-tertiary);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }

  .simple-editor-attachment:hover .simple-editor-attachment-delete {
    opacity: 1;
  }

  .simple-editor-attachment-delete:hover {
    color: var(--color-danger);
    background: color-mix(in srgb, var(--color-danger) 10%, var(--color-bg-primary));
    border-color: color-mix(in srgb, var(--color-danger) 25%, var(--color-border));
  }

  /* Image blocks */
  .simple-editor-images-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .simple-editor-image-wrapper {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-sm);
    overflow: hidden;
  }

  .simple-editor-image-preview {
    max-width: 100%;
    max-height: 300px;
    object-fit: contain;
    border-radius: var(--radius-base);
    display: block;
  }

  .simple-editor-image-filename {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: var(--spacing-xs);
  }

  /* File blocks (non-audio) */
  .simple-editor-files-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
  }

  .simple-editor-file-info {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .simple-editor-file-link {
    color: var(--color-primary);
    text-decoration: none;
    font-size: var(--text-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .simple-editor-file-link:hover {
    text-decoration: underline;
  }

  .simple-editor-file-size {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    margin-left: auto;
  }

  /* Save indicator */
  .save-indicator { font-size: var(--text-xs); }
  .save-indicator--saving { color: var(--color-accent); }
  .save-indicator--saved  { color: var(--color-success); }
  .save-indicator--error  { color: var(--color-danger); }

  /* Responsive */
  @media (max-width: 640px) {
    .simple-editor-header { padding: var(--spacing-sm) var(--spacing-md); }
    .simple-editor-title-wrapper { padding: var(--spacing-md) var(--spacing-md) 0; }
    .simple-editor-body { padding: var(--spacing-sm) var(--spacing-md) var(--spacing-xl); }
    .simple-editor-title { font-size: var(--text-xl); }
  }
</style>
