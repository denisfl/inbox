<% content_for :title, "#{@document.title} - Inbox" %>
<% content_for :head do %>
  <meta name="auth-token" content="<%= ENV['API_TOKEN'] || 'development_token' %>">
<% end %>

<div class="document-editor-container" 
     data-controller="document-editor"
     data-document-editor-document-id-value="<%= @document.id %>"
     data-document-editor-save-url-value="/api/documents/<%= @document.id %>">
  
  <!-- Header -->
  <header class="editor-header">
    <div class="header-left">
      <%= link_to "← Back", documents_path, class: "back-link" %>
    </div>
    
    <div class="header-center">
      <h1 contenteditable="true" class="document-title"><%= @document.title %></h1>
    </div>
    
    <div class="header-right">
      <span data-document-editor-target="saveIndicator" class="save-indicator"></span>
    </div>
  </header>

  <!-- Blocks Container -->
  <main class="blocks-container" data-document-editor-target="blocksContainer">
    <% @blocks.each do |block| %>
      <%= render partial: "blocks/block", locals: { block: block } %>
    <% end %>
  </main>

  <!-- Add Block Button -->
  <div class="add-block-section">
    <button type="button" 
            class="add-block-btn"
            data-action="click->document-editor#addNewBlock">
      + Add Block
    </button>
    <p class="keyboard-hint">
      <kbd>⌘</kbd> + <kbd>Enter</kbd> to add block · 
      <kbd>⌘</kbd> + <kbd>Backspace</kbd> to delete
    </p>
  </div>
</div>

<style>
    * { box-sizing: border-box; }
    
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f5;
    }

    .document-editor-container {
      max-width: 800px;
      margin: 0 auto;
      background: white;
      min-height: 100vh;
      box-shadow: 0 0 20px rgba(0,0,0,0.1);
    }

    .editor-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 40px;
      border-bottom: 1px solid #e0e0e0;
      position: sticky;
      top: 0;
      background: white;
      z-index: 100;
    }

    .back-link {
      text-decoration: none;
      color: #666;
      font-size: 14px;
    }

    .document-title {
      font-size: 24px;
      margin: 0;
      padding: 8px;
      border: 2px solid transparent;
      outline: none;
    }

    .document-title:focus {
      border-color: #4CAF50;
      border-radius: 4px;
    }

    .save-indicator {
      font-size: 14px;
      padding: 4px 12px;
      border-radius: 4px;
    }

    .save-indicator--saving { color: #ff9800; }
    .save-indicator--saved { color: #4CAF50; }
    .save-indicator--error { color: #f44336; }

    .blocks-container {
      padding: 40px;
    }

    .block-wrapper {
      position: relative;
      margin-bottom: 16px;
      padding-left: 40px;
    }

    .block-wrapper:hover .block-controls {
      opacity: 1;
    }

    .block-controls {
      position: absolute;
      left: 0;
      top: 0;
      display: flex;
      gap: 4px;
      opacity: 0;
      transition: opacity 0.2s;
    }

    .block-controls button {
      border: none;
      background: transparent;
      cursor: pointer;
      font-size: 16px;
      padding: 4px;
    }

    .block-controls button:hover {
      background: #f0f0f0;
      border-radius: 4px;
    }

    .block-content {
      min-height: 24px;
    }

    /* Block types */
    .text-block {
      padding: 8px;
      min-height: 40px;
      line-height: 1.6;
      outline: none;
      border: 2px solid transparent;
      border-radius: 4px;
    }

    .text-block:focus {
      border-color: #4CAF50;
    }

    .heading-block {
      margin: 16px 0;
      outline: none;
    }

    .todo-block {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px;
    }

    .todo-block input[type="checkbox"] {
      width: 20px;
      height: 20px;
    }

    .todo-block span {
      flex: 1;
      outline: none;
    }

    .code-block {
      background: #f5f5f5;
      padding: 16px;
      border-radius: 8px;
      font-family: 'Courier New', monospace;
      font-size: 14px;
      overflow-x: auto;
      outline: none;
    }

    .quote-block {
      border-left: 4px solid #4CAF50;
      padding: 12px 20px;
      margin: 16px 0;
      background: #f9f9f9;
      font-style: italic;
      outline: none;
    }

    .image-block, .file-block, .link-block {
      padding: 16px;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
    }

    .image-block img {
      max-width: 100%;
      border-radius: 4px;
    }

    .link-block input {
      width: 100%;
      padding: 8px;
      border: 1px solid #e0e0e0;
      border-radius: 4px;
      margin-bottom: 8px;
    }

    .link-preview {
      padding: 12px;
      background: #f5f5f5;
      border-radius: 4px;
      color: #666;
    }

    .add-block-section {
      padding: 40px;
      text-align: center;
    }

    .add-block-btn {
      background: #4CAF50;
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
    }

    .add-block-btn:hover {
      background: #45a049;
    }

    .keyboard-hint {
      margin-top: 16px;
      color: #999;
      font-size: 14px;
    }

    kbd {
      background: #f0f0f0;
      border: 1px solid #ccc;
      border-radius: 4px;
      padding: 2px 6px;
      font-family: monospace;
      font-size: 12px;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .editor-header {
        padding: 16px 20px;
      }

      .document-title {
        font-size: 20px;
      }

      .blocks-container {
        padding: 20px;
      }

      .block-wrapper {
        padding-left: 30px;
      }

      .add-block-section {
        padding: 20px;
      }
    }
  </style>
