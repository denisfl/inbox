<% content_for :title, "#{@document.title} - Inbox" %>
<% content_for :head do %>
  <meta name="auth-token" content="<%= ENV['API_TOKEN'] || 'development_token' %>">
<% end %>

<%
  audio_mime_prefix = "audio/"
  audio_extensions  = %w[.ogg .mp3 .m4a .wav .opus .aac .flac .webm]

  text_block   = @blocks.find { |b| b.block_type == "text" }
  audio_blocks = @blocks.select do |b|
    b.block_type == "file" && b.file.attached? &&
      (b.file.content_type.to_s.start_with?(audio_mime_prefix) ||
       audio_extensions.any? { |ext| b.file.filename.to_s.end_with?(ext) })
  end
%>

<div class="simple-editor-container"
     data-controller="simple-editor"
     data-simple-editor-document-id-value="<%= @document.id %>"
     data-simple-editor-block-id-value="<%= text_block&.id.to_i %>">

  <%# ── Header ────────────────────────────────────────────────────── %>
  <header class="simple-editor-header">
    <div class="simple-editor-header-left">
      <%= link_to documents_path, class: "back-link" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back
      <% end %>
    </div>

    <div class="simple-editor-header-right">
      <span class="save-indicator" data-simple-editor-target="saveIndicator"></span>

      <%# Upload buttons %>
      <label class="simple-editor-upload-btn" title="Attach image">
        <%= heroicon :photo, width: 16, height: 16 %>
        <input type="file" accept="image/*" class="hidden"
               data-simple-editor-target="imageInput"
               data-action="change->simple-editor#handleImageChange">
      </label>

      <label class="simple-editor-upload-btn" title="Attach file">
        <%= heroicon :paper_clip, width: 16, height: 16 %>
        <input type="file" class="hidden"
               data-simple-editor-target="fileInput"
               data-action="change->simple-editor#handleFileChange">
      </label>

      <%# Preview / Edit toggle %>
      <button type="button"
              class="btn btn-sm simple-editor-preview-btn"
              data-simple-editor-target="previewToggleBtn"
              data-action="click->simple-editor#togglePreview">
        Preview
      </button>
    </div>
  </header>

  <%# ── Title ─────────────────────────────────────────────────────── %>
  <div class="simple-editor-title-wrapper">
    <h1 class="simple-editor-title"
        contenteditable="true"
        data-simple-editor-target="title"
        data-action="blur->simple-editor#saveTitle"
        spellcheck="false"><%= @document.title %></h1>
  </div>

  <%# ── Editor body ────────────────────────────────────────────────── %>
  <main class="simple-editor-body">

    <%# ── Audio players (voice / audio blocks) ─────────────────────── %>
    <% if audio_blocks.any? %>
      <div class="simple-editor-audio-section">
        <% audio_blocks.each do |ab| %>
          <div class="simple-editor-audio-player">
            <audio controls preload="metadata"
                   src="<%= url_for(ab.file) %>"
                   style="width:100%">
              Your browser does not support audio playback.
            </audio>
            <div class="simple-editor-audio-filename">
              🎙 <%= ab.file.filename %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Edit mode (default): hidden when there is no text block and audio-only document %>
    <textarea class="simple-editor-textarea<%= ' hidden' if text_block.nil? && audio_blocks.any? %>"
              data-simple-editor-target="textarea"
              data-action="input->simple-editor#scheduleAutoSave"
              placeholder="Write in Markdown…"
              spellcheck="true"
              autocomplete="off"><%= text_block&.content_hash&.dig("text") %></textarea>

    <%# Preview mode (hidden by default) %>
    <div class="hidden markdown-preview simple-editor-preview"
         data-simple-editor-target="preview"></div>
  </main>
</div>

<style>
  .back-link {
    display: inline-flex;
    gap: var(--spacing-sm);
    align-items: center;
  }
  .simple-editor-container {
    max-width: 800px;
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-bg, #fff);
  }

  /* Header */
  .simple-editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
    position: sticky;
    top: 0;
    background: var(--color-bg, #fff);
    z-index: 100;
  }

  .simple-editor-header-left,
  .simple-editor-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Upload icon buttons */
  .simple-editor-upload-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 5px 7px;
    border-radius: 6px;
    color: var(--color-text-muted, #6b7280);
    border: 1px solid var(--color-border, #e5e7eb);
    background: none;
    transition: background 150ms, color 150ms;
    line-height: 1;
  }

  .simple-editor-upload-btn:hover {
    background: var(--color-bg-secondary, #f3f4f6);
    color: var(--color-text, #111827);
  }

  /* Preview toggle button */
  .simple-editor-preview-btn {
    font-size: 0.8rem;
    padding: 4px 12px;
  }

  /* Title */
  .simple-editor-title-wrapper {
    padding: 24px 32px 0;
  }

  .simple-editor-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
    padding: 4px 0;
    outline: none;
    border-bottom: 2px solid transparent;
    word-break: break-word;
    color: var(--color-text, #111827);
  }

  .simple-editor-title:focus {
    border-bottom-color: var(--color-primary, #3b82f6);
  }

  /* Body */
  .simple-editor-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 16px 32px 40px;
  }

  /* Textarea */
  .simple-editor-textarea {
    flex: 1;
    width: 100%;
    min-height: calc(100vh - 200px);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text, #111827);
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    padding: 0;
    box-sizing: border-box;
  }

  .simple-editor-textarea::placeholder {
    color: var(--color-text-muted, #9ca3af);
  }

  /* Preview pane */
  .simple-editor-preview {
    min-height: calc(100vh - 200px);
    line-height: 1.7;
    word-break: break-word;
  }

  /* Audio players */
  .simple-editor-audio-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .simple-editor-audio-player {
    background: var(--color-bg-secondary, #f3f4f6);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    padding: 12px 16px;
  }

  .simple-editor-audio-filename {
    font-size: 0.75rem;
    color: var(--color-text-muted, #6b7280);
    margin-top: 6px;
  }

  /* Save indicator */
  .save-indicator { font-size: 0.75rem; }
  .save-indicator--saving { color: var(--color-warning, #f59e0b); }
  .save-indicator--saved  { color: var(--color-success, #10b981); }
  .save-indicator--error  { color: var(--color-danger,  #ef4444); }

  /* Responsive */
  @media (max-width: 640px) {
    .simple-editor-header { padding: 10px 16px; }
    .simple-editor-title-wrapper { padding: 16px 16px 0; }
    .simple-editor-body { padding: 12px 16px 32px; }
    .simple-editor-title { font-size: 1.5rem; }
  }
</style>
