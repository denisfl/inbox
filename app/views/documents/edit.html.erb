<% content_for :title, "#{@document.title} - Inbox" %>
<% content_for :head do %>
  <meta name="auth-token" content="<%= ENV['API_TOKEN'] || 'development_token' %>">
<% end %>

<%
  audio_mime_prefix = "audio/"
  audio_extensions  = %w[.ogg .mp3 .m4a .wav .opus .aac .flac .webm]

  audio_blocks = @blocks.select do |b|
    b.block_type == "file" && b.file.attached? &&
      (b.file.content_type.to_s.start_with?(audio_mime_prefix) ||
       audio_extensions.any? { |ext| b.file.filename.to_s.end_with?(ext) })
  end

  image_blocks = @blocks.select { |b| b.block_type == "image" && b.image.attached? }
  file_blocks  = @blocks.select do |b|
    b.block_type == "file" && b.file.attached? &&
      !b.file.content_type.to_s.start_with?(audio_mime_prefix) &&
      audio_extensions.none? { |ext| b.file.filename.to_s.end_with?(ext) }
  end
%>

<div class="simple-editor-container"
     data-controller="simple-editor document-autosave"
     data-simple-editor-document-id-value="<%= @document.id %>"
     data-simple-editor-block-id-value="0">

  <%# ── Header ────────────────────────────────────────────────────── %>
  <header class="simple-editor-header">
    <div class="simple-editor-header-left">
      <%= back_link(documents_path, "Documents") %>
    </div>

    <div class="simple-editor-header-right">
      <span class="save-indicator" data-document-autosave-target="indicator" data-simple-editor-target="saveIndicator"></span>

      <button class="save-btn" type="submit" form="document-body-form">Save</button>

      <div class="options-dropdown"
           data-controller="audio-recorder"
           data-audio-recorder-document-id-value="<%= @document.id %>">
        <button class="options-btn" type="button" aria-label="Options" data-options-toggle>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="5" cy="12" r="2"/>
            <circle cx="12" cy="12" r="2"/>
            <circle cx="19" cy="12" r="2"/>
          </svg>
        </button>

        <div class="options-menu">
          <label class="options-menu-item">
            <%= heroicon(:photo, style: 'width: 16px; height: 16px;') %>
            Attach images
            <input type="file" accept="image/*" multiple class="hidden"
                   data-simple-editor-target="imageInput"
                   data-action="change->simple-editor#handleImageChange">
          </label>

          <label class="options-menu-item">
            <%= heroicon(:paper_clip, style: 'width: 16px; height: 16px;') %>
            Attach files
            <input type="file" multiple class="hidden"
                   data-simple-editor-target="fileInput"
                   data-action="change->simple-editor#handleFileChange">
          </label>

          <button type="button" class="options-menu-item"
                  data-action="click->audio-recorder#toggleRecording"
                  data-audio-recorder-target="recordBtn">
            <%= heroicon(:microphone, style: 'width: 16px; height: 16px;') %>
            Record audio
          </button>

          <% if audio_blocks.any? %>
            <button type="button" class="options-menu-item"
                    data-action="click->simple-editor#transcribeAudio"
                    data-simple-editor-target="transcribeBtn">
              <%= heroicon(:language, style: 'width: 16px; height: 16px;') %>
              Transcribe audio
            </button>
          <% end %>

          <hr class="options-menu-divider">

          <a href="<%= export_document_path(@document) %>" class="options-menu-item" download>
            <%= heroicon(:arrow_down_tray, style: 'width: 16px; height: 16px;') %>
            Export .md
          </a>
          <hr class="options-menu-divider">
          <%= button_to document_path(@document), method: :delete,
                class: "options-menu-item options-menu-item--danger",
                form: { data: { turbo_confirm: "Delete \"#{j @document.title.truncate(40)}\"? This will remove the note and all attached files. This cannot be undone." } } do %>
            <%= heroicon(:trash, style: 'width: 16px; height: 16px;') %>
            Delete note
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <%# ── Title ─────────────────────────────────────────────────────── %>
  <div class="simple-editor-title-wrapper">
    <h1 class="simple-editor-title"
        contenteditable="true"
        data-simple-editor-target="title"
        data-action="blur->simple-editor#saveTitle"
        spellcheck="false"><%= @document.title %></h1>
  </div>

  <%# ── Tags ───────────────────────────────────────────────────────── %>
  <div class="simple-editor-tags">
    <%= render "shared/tag_input", entity_type: "document", entity: @document %>
  </div>

  <%# ── Editor body ────────────────────────────────────────────────── %>
  <main class="simple-editor-body">

    <%# ── Audio players (voice / audio blocks) ─────────────────────── %>
    <% if audio_blocks.any? %>
      <div class="simple-editor-audio-section">
        <% audio_blocks.each do |ab| %>
          <div class="simple-editor-attachment" data-block-id="<%= ab.id %>">
            <div class="simple-editor-audio-player">
              <audio controls preload="metadata"
                     src="<%= url_for(ab.file) %>"
                     style="width:100%">
                Your browser does not support audio playback.
              </audio>
              <div class="simple-editor-audio-filename">
                <%= heroicon(:microphone, style: 'width:14px;height:14px;display:inline-block;vertical-align:middle') %> <%= ab.file.filename %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Image blocks (rendered as file links) ─────────────────────── %>
    <% if image_blocks.any? %>
      <div class="simple-editor-files-section">
        <% image_blocks.each do |ib| %>
          <div class="simple-editor-attachment" data-block-id="<%= ib.id %>">
            <div class="simple-editor-file-info">
              <%= heroicon(:photo, style: "width:16px;height:16px;color:var(--color-text-tertiary);flex-shrink:0") %>
              <a href="<%= url_for(ib.image) %>" target="_blank" class="simple-editor-file-link">
                <%= ib.image.filename %>
              </a>
              <span class="simple-editor-file-size"><%= number_to_human_size(ib.image.byte_size) %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── File blocks (non-audio) ──────────────────────────────────── %>
    <% if file_blocks.any? %>
      <div class="simple-editor-files-section">
        <% file_blocks.each do |fb| %>
          <div class="simple-editor-attachment" data-block-id="<%= fb.id %>">
            <div class="simple-editor-file-info">
              <%= heroicon(:document, style: "width:16px;height:16px;color:var(--color-text-tertiary);flex-shrink:0") %>
              <a href="<%= url_for(fb.file) %>" target="_blank" class="simple-editor-file-link">
                <%= fb.file.filename %>
              </a>
              <span class="simple-editor-file-size"><%= number_to_human_size(fb.file.byte_size) %></span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Rich text editor (Lexxy) ─────────────────────────────────── %>
    <%= form_with(model: @document, url: document_path(@document), method: :patch, id: "document-body-form", class: "document-body-form", data: { document_autosave_target: "form" }) do |f| %>
      <%= f.rich_text_area :body %>
    <% end %>
  </main>
</div>

<style>
  .simple-editor-container {
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    background: var(--color-bg-primary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  /* Header */
  .simple-editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
    padding: 0 28px;
    border-bottom: 1px solid var(--color-border);
  }

  .simple-editor-header-left,
  .simple-editor-header-right {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  /* Upload icon buttons */
  .simple-editor-upload-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    width: 32px;
    height: 32px;
    padding: 0;
    border-radius: var(--radius-base);
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border);
    background: none;
    transition: background var(--transition-fast), color var(--transition-fast);
    line-height: 1;
  }

  .simple-editor-upload-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  /* Preview toggle button */
  .simple-editor-preview-btn {
    font-size: var(--text-xs);
    padding: 5px 12px;
  }

  /* Delete button */
  .simple-editor-delete-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 5px 10px;
    border-radius: var(--radius-base);
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border);
    background: none;
    transition: background var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
    line-height: 1;
  }
  .simple-editor-delete-btn:hover {
    color: var(--color-danger);
    border-color: color-mix(in srgb, var(--color-danger) 25%, var(--color-border));
    background: color-mix(in srgb, var(--color-danger) 6%, var(--color-bg-primary));
  }

  /* Save button */
  .save-btn {
    padding: 0 14px;
    height: 32px;
    font-weight: 600;
    font-size: var(--text-sm);
    color: #fff;
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-base);
    cursor: pointer;
    line-height: 1;
    transition: background var(--transition-fast);
  }
  .save-btn:hover {
    background: var(--color-primary-hover);
  }

  /* Options dropdown */
  .options-dropdown {
    position: relative;
  }
  .options-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-base);
    background: none;
    color: var(--color-text-tertiary);
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .options-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }
  .options-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 180px;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-lg);
    padding: 4px;
    z-index: 100;
  }
  .options-dropdown.open .options-menu {
    display: block;
  }
  .options-menu-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    width: 100%;
    padding: 8px 12px;
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    background: none;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .options-menu-item:hover {
    background: var(--color-bg-secondary);
  }
  .options-menu-item--danger {
    color: var(--color-danger);
  }
  .options-menu-item--danger:hover {
    background: color-mix(in srgb, var(--color-danger) 8%, var(--color-bg-primary));
  }
  .options-menu-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 4px 0;
  }

  /* Title */
  .simple-editor-title-wrapper {
    padding: var(--spacing-xl) 40px 0;
  }

  .simple-editor-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: var(--font-black);
    letter-spacing: -0.03em;
    line-height: 1.25;
    margin: 0;
    padding: var(--spacing-xs) 0;
    outline: none;
    border-bottom: 2px solid transparent;
    word-break: break-word;
    color: var(--color-text-primary);
  }

  .simple-editor-title:focus {
    border-bottom-color: var(--color-primary);
  }

  /* Body */
  .simple-editor-body {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 16rem);
    padding: var(--spacing-md) 40px 60px;
  }

  /* Make form + editor fill available height */
  .document-body-form {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .document-body-form lexxy-editor {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .document-body-form .lexxy-editor__content {
    flex: 1;
  }

  /* Transcribe button */
  .simple-editor-transcribe-action {
    padding: var(--spacing-md);
  }
  .simple-editor-transcribe-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
  }
  .simple-editor-transcribe-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Transcription pending indicator */
  .simple-editor-transcription-pending {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }
  .transcription-pending-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: transcription-spin 0.8s linear infinite;
  }
  @keyframes transcription-spin {
    to { transform: rotate(360deg); }
  }

  /* Textarea */
  .simple-editor-textarea {
    width: 100%;
    min-height: calc(100vh - 20rem);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--color-text-primary);
    background: transparent;
    border: none;
    outline: none;
    resize: none;
    overflow: hidden;
    padding: 0;
    box-sizing: border-box;
    /* Modern browsers: auto-grow natively without JS resize */
    field-sizing: content;
  }

  .simple-editor-textarea::placeholder {
    color: var(--color-text-tertiary);
  }

  /* Preview pane */
  .simple-editor-preview {
    min-height: 200px;
    line-height: 1.7;
    word-break: break-word;
  }

  /* Audio players */
  .simple-editor-audio-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  .simple-editor-audio-player {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .simple-editor-audio-filename {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: var(--spacing-xs);
  }

  /* Attachments (common wrapper with delete button) */
  .simple-editor-attachment {
    position: relative;
  }

  .simple-editor-attachment-delete {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: var(--color-bg-secondary);
    color: var(--color-text-tertiary);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
  }

  .simple-editor-attachment:hover .simple-editor-attachment-delete {
    opacity: 1;
  }

  .simple-editor-attachment-delete:hover {
    color: var(--color-danger);
    background: color-mix(in srgb, var(--color-danger) 10%, var(--color-bg-primary));
    border-color: color-mix(in srgb, var(--color-danger) 25%, var(--color-border));
  }


  /* File blocks (non-audio, images) */
  .simple-editor-files-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-lg);
  }

  .simple-editor-file-info {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-sm) var(--spacing-md);
  }

  .simple-editor-file-link {
    color: var(--color-primary);
    text-decoration: none;
    font-size: var(--text-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .simple-editor-file-link:hover {
    text-decoration: underline;
  }

  .simple-editor-file-size {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    margin-left: auto;
  }

  /* Save indicator */
  .save-indicator { font-size: var(--text-xs); }
  .save-indicator--saving { color: var(--color-accent); }
  .save-indicator--saved  { color: var(--color-success); }
  .save-indicator--error  { color: var(--color-danger); }

  /* ── Tag input in editor ── */
  .simple-editor-tags {
    padding: 0 40px;
    margin-bottom: var(--spacing-sm);
  }

  /* Audio recorder */
  .simple-editor-record-group {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .simple-editor-upload-btn.is-recording {
    color: var(--color-danger);
    border-color: color-mix(in srgb, var(--color-danger) 40%, var(--color-border));
    background: color-mix(in srgb, var(--color-danger) 8%, var(--color-bg-primary));
  }

  .simple-editor-recording-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    color: var(--color-danger);
    font-variant-numeric: tabular-nums;
  }

  .recording-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-danger);
    display: inline-block;
    animation: pulse-recording 1s ease-in-out infinite;
  }

  @keyframes pulse-recording {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.3; }
  }

  /* Responsive */
  @media (max-width: 640px) {
    .simple-editor-header { padding: 0 var(--spacing-md); }
    .simple-editor-title-wrapper { padding: var(--spacing-md) var(--spacing-md) 0; }
    .simple-editor-body { padding: var(--spacing-sm) var(--spacing-md) var(--spacing-xl); }
    .simple-editor-title { font-size: 22px; font-weight: 800; }
    .simple-editor-tags { padding: 0 var(--spacing-md); }

    /* Textarea fills remaining screen space:
       100dvh - content-padding(32px) - editor-header(40px)
       - title(48px) - tags(32px) - body-padding(40px) - bottom-nav(56px) */
    .simple-editor-textarea {
      min-height: calc(100dvh - 248px - var(--bottom-nav-height, 56px));
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const toggle = document.querySelector("[data-options-toggle]");
    const dropdown = toggle && toggle.closest(".options-dropdown");
    if (!toggle || !dropdown) return;

    toggle.addEventListener("click", function (e) {
      e.stopPropagation();
      dropdown.classList.toggle("open");
    });

    document.addEventListener("click", function (e) {
      if (!dropdown.contains(e.target)) {
        dropdown.classList.remove("open");
      }
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        dropdown.classList.remove("open");
      }
    });
  });
</script>
