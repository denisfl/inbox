<% content_for :title, "Inbox - Documents" %>
<% content_for :page_title, @page_title || "All Notes" %>

<div class="documents-container">
  <%# Filters and sorting bar %>
  <div class="filters-bar">
    <div class="filters-left">
      <span class="results-count">
        <%= pluralize(@pagy.count, 'document') %>
      </span>

    </div>

    <div class="filters-right">
      <div class="sort-dropdown">
        <label for="sort-select" class="sr-only">Sort by</label>
        <select id="sort-select" class="input input-sm" onchange="window.location.href='<%= request.path %>?<%= request.query_parameters.except(:sort).to_query %>&sort=' + this.value">
          <option value="updated_desc" <%= 'selected' if params[:sort] == 'updated_desc' || params[:sort].blank? %>>Recently updated</option>
          <option value="created_desc" <%= 'selected' if params[:sort] == 'created_desc' %>>Newest first</option>
          <option value="created_asc" <%= 'selected' if params[:sort] == 'created_asc' %>>Oldest first</option>
          <option value="title_asc" <%= 'selected' if params[:sort] == 'title_asc' %>>Title (A-Z)</option>
          <option value="title_desc" <%= 'selected' if params[:sort] == 'title_desc' %>>Title (Z-A)</option>
        </select>
      </div>
    </div>
  </div>

  <%# Documents grid %>
  <% if @documents.any? %>
    <div class="documents-grid">
      <% @documents.each do |document| %>
        <%= render 'documents/card', document: document %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <% if params[:q].present? %>
        <%# No search results %>
        <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
        </svg>
        <h2 class="empty-state-title">No results found</h2>
        <p class="empty-state-description">
          We couldn't find any notes matching "<strong><%= params[:q] %></strong>"<br>
          Try a different search term or clear filters
        </p>
        <div class="empty-state-actions">
          <%= link_to root_path, class: "btn btn-secondary" do %>
            Clear search
          <% end %>
        </div>
      
      <% elsif params[:source].present? || params[:type].present? || params[:tag].present? %>
        <%# No results for filters %>
        <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z" />
        </svg>
        <h2 class="empty-state-title">No matches for current filters</h2>
        <p class="empty-state-description">
          Try adjusting your filters or browse all notes
        </p>
        <div class="empty-state-actions">
          <%= link_to root_path, class: "btn btn-secondary" do %>
            Clear all filters
          <% end %>
        </div>
      
      <% else %>
        <%# No documents at all %>
        <svg class="empty-state-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
        </svg>
        <h2 class="empty-state-title">No documents yet</h2>
        <p class="empty-state-description">
          Start capturing your thoughts by creating a new note or sending messages to your Telegram bot
        </p>
        <div class="empty-state-actions">
          <%= link_to new_note_path, class: "btn btn-primary", data: { turbo: false } do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            New Note
          <% end %>
          <a href="https://t.me/inbox_fl_bot" target="_blank" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
            </svg>
            Open Telegram Bot
          </a>
        </div>
      <% end %>
    </div>

    <%# Pagy pagination %>
    <% if @pagy.pages > 1 %>
      <div class="pagination-wrapper">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% end %>
</div>

<style>
.documents-container {
  width: 100%;
}

.filters-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.filters-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.results-count {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-medium);
}

.filters-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.sort-dropdown {
  position: relative;
}

.input-sm {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: var(--text-sm);
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

.documents-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--spacing-lg);
}

@media (max-width: 768px) {
  .documents-grid {
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }

  .filters-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .filters-right {
    width: 100%;
  }

  .sort-dropdown {
    width: 100%;
  }

  .sort-dropdown select {
    width: 100%;
  }
}

</style>
