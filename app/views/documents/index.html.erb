<% content_for :title, "Inbox - Documents" %>

<div class="container">
  <header>
    <h1>📥 Inbox</h1>
    <p class="subtitle">Your block-based notes</p>
  </header>

  <main>
    <div class="documents-list">
      <% if @documents.any? %>
          <% @documents.each do |document| %>
            <div class="document-card">
              <h2><%= link_to document.title, edit_document_path(document) %></h2>
              <div class="document-meta">
                <span class="block-count"><%= pluralize(document.blocks.size, "block") %></span>
                <span class="tags">
                  <% document.tags.each do |tag| %>
                    <span class="tag"><%= tag.name %></span>
                  <% end %>
                </span>
                <span class="updated">Updated <%= time_ago_in_words(document.updated_at) %> ago</span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="empty-state">
            <p>No documents yet.</p>
            <p class="hint">Create one via Telegram bot or API</p>
          </div>
        <% end %>
      </div>
    </main>
  </div>

  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f5f5f5;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    header {
      text-align: center;
      margin-bottom: 40px;
    }

    header h1 {
      font-size: 48px;
      margin: 0;
      color: #333;
    }

    .subtitle {
      color: #666;
      margin: 8px 0 0;
      font-size: 18px;
    }

    .documents-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .document-card {
      background: white;
      padding: 24px;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .document-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    }

    .document-card h2 {
      margin: 0 0 12px;
      font-size: 20px;
    }

    .document-card h2 a {
      color: #333;
      text-decoration: none;
    }

    .document-card h2 a:hover {
      color: #4CAF50;
    }

    .document-meta {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-size: 14px;
      color: #666;
    }

    .tag {
      background: #e8f5e9;
      color: #2e7d32;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 12px;
      display: inline-block;
      margin-right: 4px;
    }

    .empty-state {
      text-align: center;
      padding: 80px 20px;
      color: #999;
    }

    .empty-state p {
      margin: 8px 0;
    }

    .hint {
      font-size: 14px;
    }

    @media (max-width: 768px) {
      .container {
        padding: 20px;
      }

      header h1 {
        font-size: 36px;
      }

      .document-card {
        padding: 20px;
      }
    }
  </style>
