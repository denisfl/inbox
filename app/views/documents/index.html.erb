<% content_for :title, "Inbox - Documents" %>
<% content_for :page_title, @page_title || "All Notes" %>

<div class="inbox-with-sidebar">
  <div class="inbox-main">

<div class="documents-container">
  <%# Filters and sorting bar %>
  <div class="filters-bar">
    <div class="filters-left">
      <span class="results-count">
        <%= pluralize(@pagy.count, 'document') %>
      </span>

    </div>

    <div class="filters-right">
      <div class="sort-dropdown">
        <label for="sort-select" class="sr-only">Sort by</label>
        <select id="sort-select" class="input input-sm" onchange="window.location.href='<%= request.path %>?<%= request.query_parameters.except(:sort).to_query %>&sort=' + this.value">
          <option value="updated_desc" <%= 'selected' if params[:sort] == 'updated_desc' || params[:sort].blank? %>>Recently updated</option>
          <option value="created_desc" <%= 'selected' if params[:sort] == 'created_desc' %>>Newest first</option>
          <option value="created_asc" <%= 'selected' if params[:sort] == 'created_asc' %>>Oldest first</option>
          <option value="title_asc" <%= 'selected' if params[:sort] == 'title_asc' %>>Title (A-Z)</option>
          <option value="title_desc" <%= 'selected' if params[:sort] == 'title_desc' %>>Title (Z-A)</option>
        </select>
      </div>
    </div>
  </div>

  <%# Documents grid %>
  <% if @documents.any? %>
    <div class="documents-grid">
      <% @documents.each do |document| %>
        <%= render 'documents/card', document: document %>
      <% end %>

      <%# ── Dashed "New Note" card ── %>
      <%= link_to new_note_path, class: "new-note-card", data: { turbo: false } do %>
        <%= heroicon(:plus, style: 'width: 1.5rem; height: 1.5rem;') %>
        <span>New Note</span>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <% if params[:q].present? %>
        <%# No search results %>
        <%= heroicon(:magnifying_glass, class: 'empty-state-icon') %>
        <h2 class="empty-state-title">No results found</h2>
        <p class="empty-state-description">
          We couldn't find any notes matching "<strong><%= params[:q] %></strong>"<br>
          Try a different search term or clear filters
        </p>
        <div class="empty-state-actions">
          <%= link_to documents_path, class: "btn btn-secondary" do %>
            Clear search
          <% end %>
        </div>

      <% elsif params[:source].present? || params[:type].present? || params[:tag].present? %>
        <%# No results for filters %>
        <%= heroicon(:funnel, class: 'empty-state-icon') %>
        <h2 class="empty-state-title">No matches for current filters</h2>
        <p class="empty-state-description">
          Try adjusting your filters or browse all notes
        </p>
        <div class="empty-state-actions">
          <%= link_to documents_path, class: "btn btn-secondary" do %>
            Clear all filters
          <% end %>
        </div>

      <% else %>
        <%# No documents at all %>
        <%= heroicon(:clipboard, class: 'empty-state-icon') %>
        <h2 class="empty-state-title">No documents yet</h2>
        <p class="empty-state-description">
          Start capturing your thoughts by creating a new note or sending messages to your Telegram bot
        </p>
        <div class="empty-state-actions">
          <%= link_to new_note_path, class: "btn btn-primary", data: { turbo: false } do %>
            <%= heroicon(:plus, style: 'width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;') %>
            New Note
          <% end %>
          <a href="https://t.me/inbox_fl_bot" target="_blank" class="btn btn-secondary">
            <%= heroicon(:device_phone_mobile, style: 'width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;') %>
            Open Telegram Bot
          </a>
        </div>
      <% end %>
    </div>

    <%# Pagy pagination %>
    <% if @pagy.pages > 1 %>
      <div class="pagination-wrapper">
        <%== pagy_nav(@pagy) %>
      </div>
    <% end %>
  <% end %>
</div>

<style>
.documents-container {
  width: 100%;
}

.filters-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.filters-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.results-count {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-medium);
}

.filters-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.sort-dropdown {
  position: relative;
}

.input-sm {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: var(--text-sm);
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

.documents-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: var(--spacing-lg);
}

/* ── Dashed "New Note" card ── */
.new-note-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  min-height: 140px;
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-md);
  color: var(--color-text-tertiary);
  text-decoration: none;
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
}
.new-note-card:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-bg-secondary);
}

@media (max-width: 768px) {
  .documents-grid {
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
  }

  .filters-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .filters-right {
    width: 100%;
  }

  .sort-dropdown {
    width: 100%;
  }

  .sort-dropdown select {
    width: 100%;
  }
}

</style>

<%# Close inbox-main %>
  </div><%# .inbox-main %>
</div><%# .inbox-with-sidebar %>
