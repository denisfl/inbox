<% content_for :title, "Inbox - Documents" %>
<% content_for :page_title, @page_title || "All Notes" %>

<div class="inbox-with-sidebar">
  <div class="inbox-main">

<div class="documents-container">
  <%# Header %>
  <header class="documents-header">
    <h1 class="documents-page-title">
      <%= heroicon(:document_text, style: 'width: 1.5rem; height: 1.5rem;') %>
      <%= @page_title || "All Docs" %>
    </h1>

    <%= link_to new_note_path, class: "btn btn-primary btn-sm", data: { turbo: false } do %>
      <%= heroicon(:plus, style: 'width: 1rem; height: 1rem;') %>
      New Note
    <% end %>
  </header>

  <%# Tag filter bar — always shown when tags exist or tags are selected %>
  <% if @selected_tags.any? || Tag.any? %>
    <%= render partial: "shared/tag_filter_bar", locals: {
      selected_tags: @selected_tags,
      base_path: documents_path,
      preserve: { sort: params[:sort], type: params[:type], q: params[:q] }.compact_blank
    } %>
  <% end %>

  <%# Filters and sorting bar %>
  <div class="filters-bar">
    <div class="filters-left">
      <span class="results-count">
        <%= pluralize(@pagy.count, 'document') %>
      </span>

    </div>

    <div class="filters-right">
      <div class="sort-dropdown">
        <label for="sort-select" class="sr-only">Sort by</label>
        <select id="sort-select" class="input input-sm" onchange="window.location.href='<%= request.path %>?<%= request.query_parameters.except(:sort).to_query %>&sort=' + this.value">
          <option value="updated_desc" <%= 'selected' if params[:sort] == 'updated_desc' || params[:sort].blank? %>>Recently updated</option>
          <option value="created_desc" <%= 'selected' if params[:sort] == 'created_desc' %>>Newest first</option>
          <option value="created_asc" <%= 'selected' if params[:sort] == 'created_asc' %>>Oldest first</option>
          <option value="title_asc" <%= 'selected' if params[:sort] == 'title_asc' %>>Title (A-Z)</option>
          <option value="title_desc" <%= 'selected' if params[:sort] == 'title_desc' %>>Title (Z-A)</option>
        </select>
      </div>
    </div>
  </div>

  <%# Documents grid %>
  <% if @documents.any? %>
    <div class="documents-grid">
      <% @documents.each do |document| %>
        <%= render 'documents/card', document: document %>
      <% end %>

      <%# ── Dashed "New Note" card ── %>
      <%= link_to new_note_path, class: "new-note-card", data: { turbo: false } do %>
        <%= heroicon(:plus, style: 'width: 1.5rem; height: 1.5rem;') %>
        <span>New Note</span>
      <% end %>

      <%# ── Upload files card ── %>
      <%= form_with url: bulk_upload_documents_path, method: :post, multipart: true, class: "upload-card", data: { controller: "file-upload", turbo: false } do %>
        <label class="upload-card-label" data-file-upload-target="dropzone" data-action="dragover->file-upload#dragover dragenter->file-upload#dragenter dragleave->file-upload#dragleave drop->file-upload#drop">
          <%= heroicon(:arrow_up_tray, style: 'width: 1.5rem; height: 1.5rem;') %>
          <span data-file-upload-target="label">Upload Files</span>
          <input type="file" name="files[]" multiple class="upload-input" data-file-upload-target="input" data-action="change->file-upload#change">
        </label>
        <button type="submit" class="upload-submit btn btn-primary btn-sm" data-file-upload-target="submit" style="display:none">
          <%= heroicon(:arrow_up_tray, style: 'width: 0.875rem; height: 0.875rem;') %>
          Upload
        </button>
      <% end %>
    </div>

    <%# Pagy pagination %>
    <% if @pagy.pages > 1 %>
      <div class="pagination-wrapper">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  <% else %>
    <% if params[:q].present? %>
      <%# No search results %>
      <% search_actions = capture do %>
        <div class="empty-state-actions">
          <%= link_to "Clear search", documents_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
      <%= render "shared/empty_state",
            icon: :magnifying_glass,
            title: "No results found",
            description: "We couldn't find any notes matching \"#{params[:q]}\". Try a different search term or clear filters.".html_safe,
            actions: search_actions %>

    <% elsif params[:type].present? || params[:tag].present? || params[:tags].present? %>
      <%# No results for filters %>
      <% filter_actions = capture do %>
        <div class="empty-state-actions">
          <%= link_to "Clear all filters", documents_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
      <%= render "shared/empty_state",
            icon: :funnel,
            title: "No matches for current filters",
            description: "Try adjusting your filters or browse all notes",
            actions: filter_actions %>

    <% else %>
      <%# No documents at all %>
      <% doc_actions = capture do %>
        <div class="empty-state-actions">
          <%= link_to new_note_path, class: "btn btn-primary", data: { turbo: false } do %>
            <%= heroicon(:plus, style: 'width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;') %>
            New Note
          <% end %>
          <a href="https://t.me/<%= ENV.fetch('TELEGRAM_BOT_NAME', 'your_bot') %>" target="_blank" class="btn btn-secondary">
            <%= heroicon(:device_phone_mobile, style: 'width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;') %>
            Open Telegram Bot
          </a>
        </div>
      <% end %>
      <%= render "shared/empty_state",
            icon: :clipboard,
            title: "No documents yet",
            description: "Start capturing your thoughts by creating a new note or sending messages to your Telegram bot",
            actions: doc_actions %>
    <% end %>
  <% end %>
</div>

<style>
.documents-container {
  width: 100%;
}

/* ── Header ──────────────────────────────────────────────────────── */
.documents-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
}

.documents-page-title {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--color-text-primary);
  margin: 0;
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.filters-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-lg);
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.filters-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.results-count {
  font-size: var(--text-sm);
  color: var(--color-text-secondary);
  font-weight: var(--font-medium);
}

.filters-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.sort-dropdown {
  position: relative;
}

.input-sm {
  padding: var(--spacing-xs) var(--spacing-sm);
  font-size: var(--text-sm);
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border-width: 0;
}

/* ── Dashed "New Note" card ── */
.new-note-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  min-height: 140px;
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-lg);
  color: var(--color-text-tertiary);
  text-decoration: none;
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);
}
.new-note-card:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  background: var(--color-bg-secondary);
}

/* ── Upload card ── */
.upload-card {
  display: flex;
  flex-direction: column;
  min-height: 140px;
  border: 2px dashed var(--color-border);
  border-radius: var(--radius-lg);
  transition: border-color var(--transition-fast), background var(--transition-fast);
}
.upload-card.drag-over {
  border-color: var(--color-primary);
  background: var(--color-bg-secondary);
}
.upload-card-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  color: var(--color-text-tertiary);
  font-size: var(--text-xs);
  font-weight: var(--font-medium);
  cursor: pointer;
  transition: color var(--transition-fast);
  padding: var(--spacing-md);
}
.upload-card-label:hover {
  color: var(--color-primary);
}
.upload-input {
  display: none;
}
.upload-submit {
  margin: 0 var(--spacing-sm) var(--spacing-sm);
  gap: var(--spacing-xs);
  display: flex;
  align-items: center;
  justify-content: center;
}

@media (max-width: 768px) {
  .documents-header {
    margin-bottom: var(--spacing-md);
  }

  .documents-page-title {
    font-size: var(--text-lg);
  }

  .filters-bar {
    flex-direction: column;
    align-items: stretch;
  }

  .filters-right {
    width: 100%;
  }

  .sort-dropdown {
    width: 100%;
  }

  .sort-dropdown select {
    width: 100%;
  }
}

</style>

<%# Close inbox-main %>
  </div><%# .inbox-main %>
</div><%# .inbox-with-sidebar %>
