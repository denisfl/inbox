<header class="app-header">
  <div class="header-content">
    <div class="header-left">
      <%# Logo with Inbox icon %>
      <%= link_to root_path, class: "header-logo" do %>
        <%= heroicon(:inbox, style: 'width: 1.75rem; height: 1.75rem;') %>
        <span class="logo-text">Inbox</span>
      <% end %>
    </div>


    <div class="header-right">

      <%# Calendar link %>
      <%= link_to calendar_path, class: "btn btn-icon #{'btn-icon--active' if controller_name == 'calendars'}",
            "aria-label": "Calendar", title: "Calendar" do %>
        <%= heroicon(:calendar_days, style: 'width: 1.25rem; height: 1.25rem;') %>
      <% end %>

      <%# Search button with popup input %>
      <div class="search-container" data-controller="search">
        <button class="btn btn-icon"
                aria-label="Search"
                data-action="click->search#toggleSearch">
          <%= heroicon(:magnifying_glass, style: 'width: 1.25rem; height: 1.25rem;') %>
        </button>

        <div class="search-popup" data-search-target="popup" style="display: none;">
          <input type="text"
                 class="search-input"
                 placeholder="Search notes..."
                 data-search-target="input"
                 data-action="keyup->search#handleKeyup">
        </div>
      </div>

      <%= link_to new_note_path, class: "btn btn-success", data: { turbo: false } do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 1.25rem; height: 1.25rem; margin-right: 0.5rem;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Note
      <% end %>

    </div>
  </div>
</header>

<style>
.app-header { }

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-lg);
  max-width: 100%;
}

.header-left,
.header-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.header-logo {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  text-decoration: none;
  color: var(--color-text-primary);
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  transition: opacity var(--transition-fast);
}

.header-logo:hover {
  opacity: 0.7;
}

.logo-text {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
}

@media (max-width: 768px) {
  .logo-text {
    font-size: var(--text-lg);
  }
}

.header-center {
  flex: 1;
  text-align: center;
}

.page-title {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  color: var(--color-text-primary);
  margin: 0;
}

.page-title-desktop {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--color-text-primary);
  margin: 0;
}

/* Search popup */
.search-container {
  position: relative;
}

.search-popup {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: white;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-lg);
  padding: var(--spacing-sm);
  z-index: var(--z-dropdown);
  min-width: 300px;
}

.search-input {
  width: 100%;
  padding: var(--spacing-sm);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-base);
  font-size: var(--text-base);
  outline: none;
}

.search-input:focus {
  border-color: var(--color-primary);
}

@media (max-width: 768px) {
  .header-content {
    padding: var(--spacing-sm) var(--spacing-md);
    gap: var(--spacing-sm);
  }
}
</style>
