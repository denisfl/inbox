<header class="app-header">
  <div class="header-content">
    <div class="header-left">
      <%# Mobile menu button %>
      <button class="btn btn-icon show-mobile" id="mobile-menu-toggle" aria-label="Toggle menu" data-action="click->sidebar#toggle">
        <%= heroicon(:bars_3, style: 'width: 1.5rem; height: 1.5rem;') %>
      </button>
      
      <h1 class="page-title show-mobile">
        <%= content_for(:page_title) || "All Notes" %>
      </h1>
    </div>

    <div class="header-center hide-mobile">
      <%# Page title for desktop %>
      <h1 class="page-title-desktop">
        <%= content_for(:page_title) || "All Notes" %>
      </h1>
    </div>

    <div class="header-right">
      <%# Search button with popup input %>
      <div class="search-container" data-controller="search">
        <button class="btn btn-icon" 
                aria-label="Search"
                data-action="click->search#toggleSearch">
          <%= heroicon(:magnifying_glass, style: 'width: 1.25rem; height: 1.25rem;') %>
        </button>
        
        <div class="search-popup" data-search-target="popup" style="display: none;">
          <input type="text" 
                 class="search-input" 
                 placeholder="Search notes..."
                 data-search-target="input"
                 data-action="keyup->search#handleKeyup">
        </div>
      </div>
    </div>
  </div>
</header>

<style>
.app-header {
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
  background-color: var(--color-bg-primary);
  border-bottom: 2px solid var(--color-border);  /* Thicker Basecamp border */
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-lg);
  max-width: 100%;
}

.header-left,
.header-right {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.header-center {
  flex: 1;
  text-align: center;
}

.page-title {
  font-size: var(--text-lg);
  font-weight: var(--font-semibold);
  color: var(--color-text-primary);
  margin: 0;
}

.page-title-desktop {
  font-size: var(--text-xl);
  font-weight: var(--font-bold);
  color: var(--color-text-primary);
  margin: 0;
}

/* Search popup */
.search-container {
  position: relative;
}

.search-popup {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: white;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-lg);
  padding: var(--spacing-sm);
  z-index: var(--z-dropdown);
  min-width: 300px;
}

.search-input {
  width: 100%;
  padding: var(--spacing-sm);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-base);
  font-size: var(--text-base);
  outline: none;
}

.search-input:focus {
  border-color: var(--color-primary);
}

@media (max-width: 768px) {
  .header-content {
    padding: var(--spacing-sm) var(--spacing-md);
    gap: var(--spacing-sm);
  }
}
</style>
