<%# Global sidebar — navigation, sources, tags %>
<aside class="sidebar" data-sidebar-target="panel">
  <%# ── Brand ── %>
  <div class="sidebar-brand">
    <%= link_to root_path, class: "sidebar-logo" do %>
      <%= heroicon(:inbox, style: 'width: 1.5rem; height: 1.5rem;') %>
      <span>Inbox</span>
    <% end %>
  </div>

  <%# ── Search ── %>
  <div class="sidebar-search">
    <%= form_tag documents_path, method: :get, class: "sidebar-search-form" do %>
      <svg class="sidebar-search-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
        <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.2"/>
        <path d="M9.5 9.5L12.5 12.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <input type="text" name="q" placeholder="Search..." value="<%= params[:q] %>"
             class="sidebar-search-input" autocomplete="off">
    <% end %>
  </div>

  <%# ── Navigation ── %>
  <div class="nav-group-label">Navigation</div>

  <%= link_to root_path, class: "nav-item #{'active' if controller_name == 'dashboard'}" do %>
    <div class="nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
      </svg>
    </div>
    Dashboard
  <% end %>

  <%= link_to documents_path, class: "nav-item #{'active' if controller_name == 'documents'}" do %>
    <div class="nav-icon">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
      </svg>
    </div>
    Documents
    <% if @sidebar_counts[:documents] > 0 %>
      <span class="count"><%= @sidebar_counts[:documents] %></span>
    <% end %>
  <% end %>

  <%= link_to calendar_path, class: "nav-item #{'active' if controller_name.in?(%w[calendars calendar_events])}" do %>
    <div class="nav-icon">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect x="1" y="2" width="12" height="11" rx="2" stroke="currentColor" stroke-width="1.2"/>
        <path d="M1 5.5h12" stroke="currentColor" stroke-width="1.1"/>
        <path d="M4.5 1V3M9.5 1V3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    </div>
    Calendar
  <% end %>

  <%= link_to tasks_path, class: "nav-item #{'active' if controller_name == 'tasks'}" do %>
    <div class="nav-icon">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect x="1.5" y="1.5" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.2"/>
        <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    Tasks
    <% if @sidebar_counts[:tasks] > 0 %>
      <span class="count"><%= @sidebar_counts[:tasks] %></span>
    <% end %>
  <% end %>

  <%# ── Sources ── %>
  <div class="nav-group-label">Sources</div>

  <%= link_to documents_path(source: "telegram"), class: "nav-item" do %>
    <div class="nav-dot" style="background:#1b4f8a"></div>
    Telegram
    <% if @sidebar_counts[:telegram] > 0 %>
      <span class="count"><%= @sidebar_counts[:telegram] %></span>
    <% end %>
  <% end %>

  <%= link_to documents_path(type: "voice"), class: "nav-item" do %>
    <div class="nav-dot" style="background:#2d6a4f"></div>
    Voice
    <% if @sidebar_counts[:voice] > 0 %>
      <span class="count"><%= @sidebar_counts[:voice] %></span>
    <% end %>
  <% end %>

  <%= link_to documents_path(source: "web"), class: "nav-item" do %>
    <div class="nav-dot" style="background:#a09890"></div>
    Manual
    <% if @sidebar_counts[:manual] > 0 %>
      <span class="count"><%= @sidebar_counts[:manual] %></span>
    <% end %>
  <% end %>

  <%# ── Tags ── %>
  <% if @sidebar_tags.present? %>
    <div class="nav-group-label">Tags</div>
    <% @sidebar_tags.each do |tag| %>
      <%= link_to documents_path(tag: tag.name), class: "nav-item" do %>
        <div class="nav-dot" style="background:<%= tag_dot_color(tag) %>"></div>
        #<%= tag.name %>
        <span class="count"><%= tag.docs_count %></span>
      <% end %>
    <% end %>
  <% end %>

  <%# ── New Note button at bottom ── %>
  <div class="sidebar-bottom">
    <%= link_to new_note_path, class: "sidebar-new-note", data: { turbo: false } do %>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M6 2V10M2 6H10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      New Note
    <% end %>
  </div>
</aside>

<style>
/* ── Sidebar ─────────────────────────────────────────────────────────────── */
.sidebar {
  width: 220px;
  height: 100vh;
  position: sticky;
  top: 0;
  background: var(--color-bg-primary);
  border-right: 1px solid var(--color-border);
  padding: var(--spacing-md) 0;
  overflow-y: auto;
  overflow-x: hidden;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  z-index: var(--z-fixed);
}

/* Brand */
.sidebar-brand {
  padding: var(--spacing-xs) var(--spacing-md) var(--spacing-md);
}
.sidebar-logo {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  text-decoration: none;
  color: var(--color-text-primary);
  font-size: var(--text-lg);
  font-weight: var(--font-bold);
  transition: opacity var(--transition-fast);
}
.sidebar-logo:hover { opacity: 0.7; }

/* Search */
.sidebar-search {
  padding: 0 var(--spacing-md) var(--spacing-md);
}
.sidebar-search-form {
  position: relative;
}
.sidebar-search-icon {
  position: absolute;
  left: 8px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-tertiary);
  pointer-events: none;
}
.sidebar-search-input {
  width: 100%;
  padding: 5px 8px 5px 28px;
  font-size: var(--text-xs);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-base);
  background: var(--color-bg-secondary);
  color: var(--color-text-primary);
  outline: none;
  transition: border-color var(--transition-fast);
}
.sidebar-search-input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-primary);
}

/* Group labels */
.nav-group-label {
  padding: var(--spacing-md) var(--spacing-md) var(--spacing-xs);
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
}

/* Nav items */
.nav-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: 6px var(--spacing-md);
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  color: var(--color-text-secondary);
  text-decoration: none;
  cursor: pointer;
  transition: background var(--transition-fast), color var(--transition-fast);
  border-left: 3px solid transparent;
}
.nav-item:hover {
  background: var(--color-bg-hover);
  color: var(--color-text-primary);
}
.nav-item.active {
  background: var(--color-bg-tertiary);
  color: var(--color-text-primary);
  border-left-color: var(--color-primary);
  font-weight: var(--font-semibold);
}

.nav-icon {
  width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--color-text-tertiary);
}
.nav-item.active .nav-icon { color: var(--color-primary); }

.nav-dot {
  width: 8px;
  height: 8px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.count {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-tertiary);
  background: var(--color-bg-tertiary);
  padding: 1px 6px;
  border-radius: var(--radius-full);
  min-width: 18px;
  text-align: center;
}

/* Bottom section */
.sidebar-bottom {
  margin-top: auto;
  padding: var(--spacing-md);
  border-top: 1px solid var(--color-border);
}
.sidebar-new-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  width: 100%;
  padding: 6px var(--spacing-md);
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: white;
  background: var(--color-secondary);
  border: none;
  border-radius: var(--radius-base);
  text-decoration: none;
  cursor: pointer;
  transition: background var(--transition-fast);
}
.sidebar-new-note:hover {
  background: #5ea06c;
}

/* ── Mobile sidebar ───────────────────────────────────────────────────────── */
.mobile-topbar {
  display: none;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-primary);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: calc(var(--z-fixed) - 1);
}
.mobile-topbar .sidebar-logo { font-size: var(--text-base); }

.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: calc(var(--z-fixed) - 1);
}

@media (max-width: 768px) {
  .sidebar {
    position: fixed;
    left: -240px;
    top: 0;
    width: 240px;
    transition: left var(--transition-base);
    box-shadow: none;
  }
  .sidebar.open {
    left: 0;
    box-shadow: var(--shadow-lg);
  }
  .mobile-topbar {
    display: flex;
  }
  .sidebar-overlay.open {
    display: block;
  }
}
</style>
