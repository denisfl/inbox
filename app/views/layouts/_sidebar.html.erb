<%# Global sidebar — navigation, sources, tags %>
<aside class="sidebar" data-sidebar-target="panel">
  <%# ── Brand ── %>
  <div class="sidebar-brand">
    <%= link_to root_path, class: "sidebar-logo" do %>
      <div class="sidebar-logo-mark">
        <%= heroicon(:inbox, style: 'width: 1rem; height: 1rem;') %>
      </div>
      <span class="sidebar-logo-name">Inbox</span>
    <% end %>
  </div>

  <%# ── Search ── %>
  <div class="sidebar-search">
    <%= form_tag documents_path, method: :get, class: "sidebar-search-form" do %>
      <%= heroicon(:magnifying_glass, class: 'sidebar-search-icon', style: 'width: 14px; height: 14px;') %>
      <input type="text" name="q" placeholder="Search..." value="<%= params[:q] %>"
             class="sidebar-search-input" autocomplete="off">
    <% end %>
  </div>

  <%# ── Navigation ── %>
  <div class="nav-group-label">Navigation</div>

  <%= link_to root_path, class: "nav-item #{'active' if controller_name == 'dashboard'}" do %>
    <div class="nav-icon"><%= heroicon(:squares_2x2, style: 'width: 14px; height: 14px;') %></div>
    Dashboard
  <% end %>

  <%= link_to inbox_documents_path, class: "nav-item #{'active' if controller_name == 'documents' && action_name == 'inbox'}" do %>
    <div class="nav-icon"><%= heroicon(:inbox, style: 'width: 14px; height: 14px;') %></div>
    Inbox
    <% if @sidebar_counts[:inbox] > 0 %>
      <span class="count"><%= @sidebar_counts[:inbox] %></span>
    <% end %>
  <% end %>

  <%= link_to documents_path, class: "nav-item #{'active' if controller_name == 'documents' && action_name != 'inbox'}" do %>
    <div class="nav-icon"><%= heroicon(:document_text, style: 'width: 14px; height: 14px;') %></div>
    Documents
    <% if @sidebar_counts[:documents] > 0 %>
      <span class="count"><%= @sidebar_counts[:documents] %></span>
    <% end %>
  <% end %>

  <%= link_to calendar_path, class: "nav-item #{'active' if controller_name.in?(%w[calendars calendar_events])}" do %>
    <div class="nav-icon"><%= heroicon(:calendar, style: 'width: 14px; height: 14px;') %></div>
    Calendar
  <% end %>

  <%= link_to tasks_path, class: "nav-item #{'active' if controller_name == 'tasks'}" do %>
    <div class="nav-icon"><%= heroicon(:clipboard, style: 'width: 14px; height: 14px;') %></div>
    Tasks
    <% if @sidebar_counts[:tasks] > 0 %>
      <span class="count"><%= @sidebar_counts[:tasks] %></span>
    <% end %>
  <% end %>

  <%= link_to tags_path, class: "nav-item #{'active' if controller_name == 'tags'}" do %>
    <div class="nav-icon"><%= heroicon(:tag, style: 'width: 14px; height: 14px;') %></div>
    Tags
  <% end %>

  <%# ── Tags ── %>
  <% if @sidebar_tags.present? %>
    <div class="nav-group-label">Tags</div>
    <% @sidebar_tags.each do |tag| %>
      <%= link_to tag_path(tag.name), class: "nav-item" do %>
        <%= render "shared/tag", tag: tag %>
        <span class="count"><%= tag.total_count > 1000 ? "1000+" : tag.total_count %></span>
      <% end %>
    <% end %>
  <% end %>

  <%# ── New Note button at bottom ── %>
  <div class="sidebar-bottom">
    <%= link_to new_note_path, class: "sidebar-new-note", data: { turbo: false } do %>
      <%= heroicon(:plus, style: 'width: 12px; height: 12px;') %>
      New Note
    <% end %>
  </div>
</aside>

<style>
/* ── Sidebar ─────────────────────────────────────────────────────────────── */
.sidebar {
  width: 220px;
  height: 100vh;
  position: sticky;
  top: 0;
  padding: 0;
  overflow-y: auto;
  overflow-x: hidden;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  z-index: var(--z-fixed);
}

/* Brand */
.sidebar-brand {
  padding: 18px 16px 14px;
  border-bottom: 1px solid var(--color-border-soft);
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  text-decoration: none;
  color: var(--color-text-primary);
  transition: opacity var(--transition-fast);
}
.sidebar-logo:hover { opacity: 0.7; }

.sidebar-logo-mark {
  width: 28px;
  height: 28px;
  background: var(--color-text-primary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sidebar-logo-mark svg {
  color: white;
}
.sidebar-logo-name {
  font-size: 17px;
  font-weight: var(--font-black, 900);
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
  font-family: var(--font-display);
}

/* Search */
.sidebar-search {
  padding: 10px 12px;
  border-bottom: 1px solid var(--color-border-soft);
}
.sidebar-search-form {
  position: relative;
}
.sidebar-search-icon {
  position: absolute;
  left: 8px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-text-quaternary);
  pointer-events: none;
}
.sidebar-search-input {
  width: 100%;
  padding: 6px 8px 6px 26px;
  font: 13px/1 var(--font-sans);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-base);
  background: var(--color-bg-tertiary);
  color: var(--color-text-primary);
  outline: none;
  transition: border-color var(--transition-fast), background var(--transition-fast);
}
.sidebar-search-input::placeholder {
  color: var(--color-text-quaternary);
}
.sidebar-search-input:focus {
  border-color: var(--color-text-tertiary);
  background: var(--color-bg-primary);
}

/* Group labels */
.nav-group-label {
  padding: 14px 16px 4px;
  font-size: 10px;
  font-weight: var(--font-bold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-quaternary);
}

/* Nav items */
.nav-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: 6px 16px 6px 13px;
  font-size: var(--text-sm);
  font-weight: var(--font-normal);
  color: var(--color-text-secondary);
  text-decoration: none;
  cursor: pointer;
  transition: background var(--transition-fast), color var(--transition-fast);
  border-left: 3px solid transparent;
}
.nav-item:hover {
  background: var(--color-bg-hover);
  color: var(--color-text-primary);
}
.nav-item.active {
  background: var(--color-primary-soft);
  color: var(--color-primary);
  border-left-color: var(--color-primary);
  font-weight: var(--font-semibold);
}

.nav-icon {
  width: 15px;
  height: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--color-text-quaternary);
}
.nav-item.active .nav-icon { color: var(--color-primary); }

.count {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 10.5px;
  font-weight: 400;
  color: var(--color-text-quaternary);
}

/* Bottom section */
.sidebar-bottom {
  margin-top: auto;
  padding: 14px;
  border-top: 1px solid var(--color-border-soft);
}
.sidebar-new-note {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 9px;
  font: 600 13.5px var(--font-sans);
  color: white;
  background: var(--color-primary);
  border: none;
  border-radius: var(--radius-md);
  text-decoration: none;
  cursor: pointer;
  transition: background var(--transition-fast);
}
.sidebar-new-note:hover {
  background: var(--color-primary-hover);
}

/* ── Mobile sidebar ───────────────────────────────────────────────────────── */

.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: calc(var(--z-fixed) - 1);
}

@media (max-width: 768px) {
  .sidebar {
    position: fixed;
    left: -240px;
    top: 0;
    width: 240px;
    transition: left var(--transition-base);
    box-shadow: none;
  }
  .sidebar.open {
    left: 0;
    box-shadow: var(--shadow-lg);
  }
  .sidebar-overlay.open {
    display: block;
  }
}
</style>
