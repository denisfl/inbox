<div class="file-block">
  <% if block.file.attached? %>
    <% is_audio = block.file.content_type&.start_with?('audio/') %>
    <div class="file-info <%= 'file-info-audio' if is_audio %>">
      <% if is_audio %>
        <%# Audio file: custom player with speed controls %>
        <div class="audio-player-wrapper" data-controller="audio-player">
          <audio data-audio-player-target="audio" data-action="timeupdate->audio-player#updateProgress">
            <source src="<%= rails_blob_path(block.file) %>" type="<%= block.file.content_type %>">
            Your browser does not support audio playback.
          </audio>
          
          <%# Custom controls %>
          <div class="audio-player-custom">
            <button type="button" 
                    class="audio-btn-play" 
                    data-action="click->audio-player#togglePlay"
                    data-audio-player-target="playButton"
                    title="Play/Pause">
              <%= heroicon(:play, variant: :solid, class: 'icon-play', style: 'width: 20px; height: 20px;') %>
              <%= heroicon(:pause, variant: :solid, class: 'icon-pause', style: 'width: 20px; height: 20px; display: none;') %>
            </button>
            
            <div class="audio-progress-bar" 
                 data-action="click->audio-player#seek"
                 data-audio-player-target="progressBar">
              <div class="audio-progress-fill" data-audio-player-target="progressFill"></div>
            </div>
            
            <span class="audio-time" data-audio-player-target="timeDisplay">0:00 / 0:00</span>
            
            <div class="audio-speed-control">
              <button type="button" 
                      class="audio-speed-btn" 
                      data-action="click->audio-player#cycleSpeed"
                      data-audio-player-target="speedButton"
                      title="Playback speed">
                1.0x
              </button>
            </div>
          </div>
        </div>
        
        <div class="audio-metadata">
          <div class="audio-filename" title="<%= block.file.filename %>">
            <%= heroicon(:microphone, style: 'width: 1rem; height: 1rem;') %>
            <%= block.file.filename.to_s.truncate(40) %>
          </div>
          <span class="file-size"><%= number_to_human_size(block.file.byte_size) %></span>
        </div>
        
        <div class="audio-actions">
          <%= link_to rails_blob_path(block.file, disposition: "attachment"), 
                      class: "btn btn-sm btn-secondary", 
                      title: "Download audio", 
                      download: block.file.filename do %>
            <%= heroicon(:arrow_down_tray, style: 'width: 16px; height: 16px;') %>
            Download
          <% end %>
        </div>
      <% else %>
        <%# Regular file: show icon, link, size %>
        <span class="file-icon">
          <%= heroicon(:document, style: 'width: 1.25rem; height: 1.25rem;') %>
        </span>
        <%= link_to block.file.filename, rails_blob_path(block.file, disposition: "attachment"), target: "_blank", class: "file-link" %>
        <span class="file-size"><%= number_to_human_size(block.file.byte_size) %></span>
      <% end %>
    </div>
  <% elsif block.content_hash["filename"].present? %>
    <span class="file-name">
      <%= heroicon(:document, style: 'width: 1.25rem; height: 1.25rem; display: inline-block; vertical-align: middle;') %>
      <%= block.content_hash["filename"] %>
    </span>
  <% else %>
    <span class="file-placeholder">No file attached</span>
  <% end %>
  <input type="file"
         data-action="change->document-editor#uploadFile"
         style="display:none">
  <button type="button"
          data-action="click->document-editor#triggerFileUpload">
    <%= block.file.attached? ? 'Change File' : 'Attach File' %>
  </button>
</div>

<style>
  .file-block {
    padding: 16px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #f9f9f9;
  }

  .file-info {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .file-info-audio {
    flex-direction: column;
    align-items: stretch;
  }

  .audio-player-wrapper {
    width: 100%;
    margin-bottom: 12px;
  }

  .audio-player-custom {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: var(--color-bg-primary);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .audio-btn-play {
    width: 36px;
    height: 36px;
    border: none;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }

  .audio-btn-play:hover {
    background: var(--color-primary-dark, #1d4ed8);
  }

  .audio-progress-bar {
    flex: 1;
    height: 6px;
    background: var(--color-bg-tertiary);
    border-radius: 3px;
    cursor: pointer;
    position: relative;
  }

  .audio-progress-fill {
    height: 100%;
    background: var(--color-primary);
    border-radius: 3px;
    width: 0%;
    transition: width 0.1s linear;
  }

  .audio-time {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    min-width: 80px;
  }

  .audio-speed-control {
    flex-shrink: 0;
  }

  .audio-speed-btn {
    padding: 4px 8px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    cursor: pointer;
    transition: all var(--transition-fast);
    min-width: 45px;
  }

  .audio-speed-btn:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-primary);
  }

  .audio-metadata {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .audio-filename {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    word-break: break-all;
  }

  .audio-actions {
    display: flex;
    gap: 8px;
  }

  .audio-player {
    width: 100%;
    max-width: 100%;
    height: 32px;
  }

  .audio-controls {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
  }

  .audio-filename {
    font-size: 14px;
    color: #666;
    word-break: break-all;
    overflow-wrap: anywhere;
  }

  .file-link {
    color: #2563eb;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }

  .file-link:hover {
    text-decoration: underline;
  }

  .file-icon {
    color: #666;
    flex-shrink: 0;
  }

  .file-size {
    color: #999;
    font-size: 14px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .file-block {
      padding: 12px;
    }

    .audio-player {
      height: 40px;
    }

    .audio-filename {
      font-size: 12px;
      word-break: break-all;
    }

    .file-info:not(.file-info-audio) {
      flex-wrap: wrap;
    }

    .file-link {
      max-width: 100%;
      word-break: break-all;
      white-space: normal;
    }
  }
</style>
