<div class="file-block">
  <% if block.file.attached? %>
    <% is_audio = block.file.content_type&.start_with?('audio/') %>
    <div class="file-info <%= 'file-info-audio' if is_audio %>">
      <% if is_audio %>
        <%# Audio file: show player, download, delete %>
        <div class="audio-player-wrapper">
          <audio controls class="audio-player">
            <source src="<%= rails_blob_path(block.file) %>" type="<%= block.file.content_type %>">
            Your browser does not support audio playback.
          </audio>
        </div>
        <div class="audio-controls">
          <%= link_to rails_blob_path(block.file, disposition: "attachment"), 
                      class: "btn btn-icon", 
                      title: "Download audio", 
                      download: block.file.filename do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          <% end %>
          <button type="button" 
                  class="btn btn-icon" 
                  title="Delete audio"
                  data-action="click->document-editor#deleteBlock">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>
        <div class="audio-filename" title="<%= block.file.filename %>">
          <%= block.file.filename.to_s.truncate(30) %>
          <span class="file-size"><%= number_to_human_size(block.file.byte_size) %></span>
        </div>
      <% else %>
        <%# Regular file: show icon, link, size %>
        <span class="file-icon">
          <%= heroicon(:document, style: 'width: 1.25rem; height: 1.25rem;') %>
        </span>
        <%= link_to block.file.filename, rails_blob_path(block.file, disposition: "attachment"), target: "_blank", class: "file-link" %>
        <span class="file-size"><%= number_to_human_size(block.file.byte_size) %></span>
      <% end %>
    </div>
  <% elsif block.content_hash["filename"].present? %>
    <span class="file-name">
      <%= heroicon(:document, style: 'width: 1.25rem; height: 1.25rem; display: inline-block; vertical-align: middle;') %>
      <%= block.content_hash["filename"] %>
    </span>
  <% else %>
    <span class="file-placeholder">No file attached</span>
  <% end %>
  <input type="file"
         data-action="change->document-editor#uploadFile"
         style="display:none">
  <button type="button"
          data-action="click->document-editor#triggerFileUpload">
    <%= block.file.attached? ? 'Change File' : 'Attach File' %>
  </button>
</div>

<style>
  .file-block {
    padding: 16px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #f9f9f9;
  }

  .file-info {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .file-info-audio {
    flex-direction: column;
    align-items: stretch;
  }

  .audio-player-wrapper {
    width: 100%;
    margin-bottom: 8px;
  }

  .audio-player {
    width: 100%;
    max-width: 100%;
    height: 32px;
  }

  .audio-controls {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
  }

  .audio-filename {
    font-size: 14px;
    color: #666;
    word-break: break-all;
    overflow-wrap: anywhere;
  }

  .file-link {
    color: #2563eb;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }

  .file-link:hover {
    text-decoration: underline;
  }

  .file-icon {
    color: #666;
    flex-shrink: 0;
  }

  .file-size {
    color: #999;
    font-size: 14px;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .file-block {
      padding: 12px;
    }

    .audio-player {
      height: 40px;
    }

    .audio-filename {
      font-size: 12px;
      word-break: break-all;
    }

    .file-info:not(.file-info-audio) {
      flex-wrap: wrap;
    }

    .file-link {
      max-width: 100%;
      word-break: break-all;
      white-space: normal;
    }
  }
</style>
