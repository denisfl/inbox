<% content_for :title, "Inbox — Dashboard" %>

<div class="dashboard">

  <%# ── Greeting ──────────────────────────────────────────────────────────── %>
  <div class="dash-greeting">
    <div class="dash-greeting-date"><%= Date.current.strftime("%A · %B %-d, %Y") %></div>
  </div>

  <%# ── Main grid ─────────────────────────────────────────────────────────── %>
  <div class="dash-grid">

    <%# ════════ LEFT COLUMN ════════ %>
    <div class="dash-left">

      <%# ── Tasks today ── %>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">
            <%= heroicon(:clipboard, style: 'width: 14px; height: 14px;') %>
            Today's Tasks
            <span style="font-family:var(--font-mono);font-size:11px;font-weight:400;color:var(--color-text-tertiary)">(<%= @tasks_today.size %>)</span>
          </div>
          <%= link_to tasks_path, class: "panel-action" do %>All tasks →<% end %>
        </div>
        <%= form_with(url: tasks_path, method: :post, class: "task-add") do |f| %>
          <%= heroicon(:plus, style: 'width: 12px; height: 12px;') %>
          <input type="text" name="task[title]" class="task-add-input" placeholder="Add task..." autocomplete="off" autofocus>
          <input type="hidden" name="task[due_date]" value="<%= Date.current.to_s %>">
          <input type="hidden" name="redirect_to" value="<%= root_path %>">
        <% end %>
        <div class="task-list">
          <% @tasks_today.each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>

          <%# Completed today %>
          <% @tasks_completed_today.each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>

          <% if @tasks_today.empty? && @tasks_completed_today.empty? %>
            <%= render "shared/empty_state",
                       icon: :check_circle,
                       title: "No tasks for today" %>
          <% end %>
        </div>

      </div>

      <%# ── Recent Documents ── %>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">
            <%= heroicon(:document_text, style: 'width: 14px; height: 14px;') %>
            Recent Documents
          </div>
          <%= link_to new_note_path, class: "panel-action", data: { turbo: false } do %><%= heroicon(:plus, style: 'width: 12px; height: 12px;') %> Add document<% end %>
        </div>
        <div>
          <% @recent_documents.each do |doc| %>
            <%
              preview_text = nil
              text_block = doc.blocks.find { |b| b.block_type == 'text' }
              if text_block && text_block.content.present?
                begin
                  data = JSON.parse(text_block.content)
                  raw = data['text'] || data[:text]
                  preview_text = raw.truncate(80) if raw.present? && raw != doc.title
                rescue JSON::ParserError
                end
              end
            %>
            <%= link_to edit_document_path(doc), class: "note-row" do %>
              <div class="note-row-info">
                <div class="note-row-title"><%= doc.title.truncate(50) %></div>
                <% if preview_text %>
                  <div class="note-row-preview"><%= preview_text %></div>
                <% end %>
              </div>
              <div class="note-row-meta">
                <span class="note-time"><%= time_ago_short(doc.created_at) %></span>
              </div>
            <% end %>
          <% end %>

          <% if @recent_documents.empty? %>
            <%= render "shared/empty_state",
                       icon: :document_text,
                       title: "No notes yet",
                       description: "Send something to Telegram or create a new note" %>
          <% end %>
        </div>
      </div>

    </div><%# .dash-left %>

    <%# ════════ RIGHT COLUMN ════════ %>
    <div class="dash-right">

      <%# ── Mini Calendar ── %>
      <div class="panel panel-calendar">
        <div class="panel-header">
          <div class="panel-title">
            <%= heroicon(:calendar, style: 'width: 13px; height: 13px;') %>
            <%= @cal_date.strftime("%B %Y") %>
          </div>
          <div style="display:flex;gap:2px">
            <%= link_to root_path(cal_month: (@cal_date - 1.month).strftime("%Y-%m")), class: "mini-cal-nav-btn" do %><%= heroicon(:chevron_left, style: 'width: 12px; height: 12px;') %><% end %>
            <%= link_to root_path(cal_month: (@cal_date + 1.month).strftime("%Y-%m")), class: "mini-cal-nav-btn" do %><%= heroicon(:chevron_right, style: 'width: 12px; height: 12px;') %><% end %>
          </div>
        </div>
        <div class="mini-cal">
          <div class="cal-grid">
            <div class="cal-dow">Mo</div>
            <div class="cal-dow">Tu</div>
            <div class="cal-dow">We</div>
            <div class="cal-dow">Th</div>
            <div class="cal-dow">Fr</div>
            <div class="cal-dow">Sa</div>
            <div class="cal-dow">Su</div>

            <%
              first_wday = cal_first_wday(@cal_date)
              days_in_month = @cal_month_end.day
              prev_month_end = @cal_month_start - 1.day
            %>

            <%# Previous month trailing days %>
            <% first_wday.times do |i| %>
              <div class="cal-day other-month"><%= prev_month_end.day - first_wday + i + 1 %></div>
            <% end %>

            <%# Current month days %>
            <% (1..days_in_month).each do |day| %>
              <%
                is_today = day == @cal_date.day && @cal_month_start.month == Date.current.month && @cal_month_start.year == Date.current.year
                has_event = @cal_event_days.include?(day)
                classes = ["cal-day"]
                classes << "today" if is_today
                classes << "has-event" if has_event
              %>
              <div class="<%= classes.join(' ') %>"><%= day %></div>
            <% end %>

            <%# Next month leading days %>
            <% remaining = (7 - (first_wday + days_in_month) % 7) % 7 %>
            <% remaining.times do |i| %>
              <div class="cal-day other-month"><%= i + 1 %></div>
            <% end %>
          </div>
        </div>
      </div>

      <%# ── Events (unified: today + upcoming) ── %>
      <div class="panel">
        <div class="panel-header">
          <div class="panel-title">
            <%= heroicon(:calendar, style: 'width: 13px; height: 13px;') %>
            Events
          </div>
          <%= link_to new_calendar_event_path, class: "panel-action" do %><%= heroicon(:plus, style: 'width: 12px; height: 12px;') %> Add Event<% end %>
        </div>
        <div class="timeline-list">
          <% has_any_events = @events_today.any? || @events_tomorrow.any? || @events_week.any? || @events_next_week.any? %>

          <% if @events_today.any? %>
            <div class="tl-section-label">Today</div>
            <% @events_today.each do |event| %>
              <div class="tl-item">
                <div class="tl-bar" style="background:<%= event.display_color %>"></div>
                <div class="tl-time"><%= event.time_label %></div>
                <div class="tl-info">
                  <div class="tl-title"><%= event.all_day? ? "All day: #{event.title}" : event.title %></div>
                  <% if event.duration_label %>
                    <div class="tl-dur"><%= event.duration_label %></div>
                  <% end %>
                </div>
                <% badge = event_source_badge(event) %>
                <div class="<%= badge[:class] %>"><%= badge[:text] %></div>
              </div>
            <% end %>
          <% end %>

          <% if @events_tomorrow.any? %>
            <div class="tl-section-label">Tomorrow</div>
            <% @events_tomorrow.each do |event| %>
              <div class="tl-item">
                <div class="tl-bar" style="background:<%= event.display_color %>"></div>
                <div class="tl-time"><%= event.time_label %></div>
                <div class="tl-info">
                  <div class="tl-title"><%= event.all_day? ? "All day: #{event.title}" : event.title %></div>
                  <% if event.duration_label %>
                    <div class="tl-dur"><%= event.duration_label %></div>
                  <% end %>
                </div>
                <% badge = event_source_badge(event) %>
                <div class="<%= badge[:class] %>"><%= badge[:text] %></div>
              </div>
            <% end %>
          <% end %>

          <% if @events_week.any? %>
            <div class="tl-section-label">This week</div>
            <% @events_week.each do |event| %>
              <div class="tl-item">
                <div class="tl-bar" style="background:<%= event.display_color %>"></div>
                <div class="tl-time"><%= event.time_label %></div>
                <div class="tl-info">
                  <div class="tl-title"><%= event.title %></div>
                  <div class="tl-dur"><%= event.duration_label %><%= " · #{event.starts_at.strftime('%a %b %-d')}" %></div>
                </div>
                <% badge = event_source_badge(event) %>
                <div class="<%= badge[:class] %>"><%= badge[:text] %></div>
              </div>
            <% end %>
          <% end %>

          <% if @events_next_week.any? %>
            <div class="tl-section-label">Next week</div>
            <% @events_next_week.each do |event| %>
              <div class="tl-item">
                <div class="tl-bar" style="background:<%= event.display_color %>"></div>
                <div class="tl-time"><%= event.time_label %></div>
                <div class="tl-info">
                  <div class="tl-title"><%= event.title %></div>
                  <div class="tl-dur"><%= event.duration_label %><%= " · #{event.starts_at.strftime('%a %b %-d')}" %></div>
                </div>
                <% badge = event_source_badge(event) %>
                <div class="<%= badge[:class] %>"><%= badge[:text] %></div>
              </div>
            <% end %>
          <% end %>

          <% unless has_any_events %>
            <%= render "shared/empty_state",
                       icon: :calendar,
                       title: "No events scheduled" %>
          <% end %>
        </div>
      </div>

      <%# ── Activity (desktop only) ── %>
      <div class="panel panel-activity">
        <div class="panel-header">
          <div class="panel-title">
            <%= heroicon(:chart_bar, style: 'width: 13px; height: 13px;') %>
            Activity
          </div>
        </div>
        <div>
          <% @activities.each do |act| %>
            <div class="activity-item">
              <div class="activity-icon <%= "activity-icon--#{act[:icon_type]}" %>">
                <% case act[:icon_type] %>
                <% when :telegram %>
                  <%= heroicon(:paper_airplane, style: 'width: 11px; height: 11px;') %>
                <% when :task_done %>
                  <%= heroicon(:check_circle, style: 'width: 11px; height: 11px;') %>
                <% when :task_new %>
                  <%= heroicon(:plus_circle, style: 'width: 11px; height: 11px;') %>
                <% when :voice %>
                  <%= heroicon(:microphone, style: 'width: 11px; height: 11px;') %>
                <% when :calendar %>
                  <%= heroicon(:calendar, style: 'width: 11px; height: 11px;') %>
                <% else %>
                  <%= heroicon(:document_text, style: 'width: 11px; height: 11px;') %>
                <% end %>
              </div>
              <div class="activity-text"><%= act[:text].html_safe %></div>
              <div class="activity-time"><%= time_ago_short(act[:time]) %></div>
            </div>
          <% end %>

          <% if @activities.empty? %>
            <%= render "shared/empty_state",
                       icon: :chart_bar,
                       title: "No activity yet" %>
          <% end %>
        </div>
      </div>

    </div><%# .dash-right %>
  </div><%# .dash-grid %>
</div><%# .dashboard %>

<%# ── Flash messages ── %>
<% if flash[:notice] %>
  <div class="flash-notice"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="flash-alert"><%= flash[:alert] %></div>
<% end %>

<style>
/* ═══════════════════════════════════════════════════════════════════════════
   DASHBOARD STYLES
   ═══════════════════════════════════════════════════════════════════════════ */

.dashboard {
  width: 100%;
  max-width: 100%;
  overflow: hidden;
}

/* ── Greeting ── */
.dash-greeting {
  margin-bottom: var(--spacing-lg);
}
.dash-greeting-date {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  margin-bottom: 4px;
}

/* ── Main grid ── */
.dash-grid {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: var(--spacing-lg);
  align-items: start;
  overflow: hidden;
}
.dash-left, .dash-right {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
  min-width: 0;
}

/* ── Panel (card wrapper) ── */
.panel {
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  border-bottom: 1px solid var(--color-border);
}
.panel-title {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: var(--text-sm);
  font-weight: var(--font-semibold);
  color: var(--color-text-primary);
}
.panel-action {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: var(--font-bold);
  letter-spacing: 0.04em;
  color: var(--color-text-tertiary);
  text-decoration: none;
  transition: color var(--transition-fast);
  display: inline-flex;
  gap: var(--spacing-sm);
  align-items: center;
}
.panel-action:hover { color: var(--color-primary); }

/* ── Task list (dashboard compact overrides) ── */
.task-list .task-item-actions {
  display: none;
}

/* ── Task add form ── */
.task-add {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: var(--spacing-sm) var(--spacing-md);
  font-size: var(--text-sm);
  color: var(--color-text-tertiary);
  cursor: pointer;
  transition: color var(--transition-fast), background var(--transition-fast);
  text-decoration: none;
  border-top: 1px solid var(--color-border);
}
.task-add:hover {
  color: var(--color-primary);
  background: var(--color-bg-secondary);
}
.task-add-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  outline: none;
  font-family: inherit;
}
.task-add-input::placeholder {
  color: var(--color-text-tertiary);
}

/* ── Timeline / Event list ── */
.timeline-list {
  padding: 0;
}
.tl-section-label {
  padding: 6px 16px 2px;
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
}
.tl-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  border-bottom: 1px solid var(--color-bg-tertiary);
  font-size: var(--text-sm);
}
.tl-item:last-child { border-bottom: none; }

.tl-bar {
  width: 3px;
  height: 28px;
  border-radius: 2px;
  flex-shrink: 0;
}
.tl-time {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-secondary);
  min-width: 36px;
  flex-shrink: 0;
}
.tl-info { flex: 1; min-width: 0; }
.tl-title {
  font-weight: var(--font-medium);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tl-dur {
  font-size: 11px;
  color: var(--color-text-tertiary);
}
.tl-src {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  letter-spacing: 0.02em;
}
.tl-src.gcal {
  background: #e8f0fe;
  color: #1a73e8;
  border: 1px solid #c5d9f7;
}
.tl-src.manual {
  background: var(--color-bg-tertiary);
  color: var(--color-text-tertiary);
  border: 1px solid var(--color-border);
}

/* ── Recent notes ── */
.note-row {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  border-bottom: 1px solid var(--color-bg-tertiary);
  text-decoration: none;
  color: inherit;
  transition: background var(--transition-fast);
}
.note-row:hover { background: var(--color-bg-secondary); }
.note-row:last-child { border-bottom: none; }

.note-row-info { flex: 1; min-width: 0; }
.note-row-title {
  font-weight: var(--font-medium);
  font-size: var(--text-sm);
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.note-row-preview {
  font-size: 13px;
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 1px;
}
.note-row-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 3px;
  flex-shrink: 0;
}
.note-time {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-tertiary);
}

/* ── Quick Capture ── */
.quick-capture {
  background: var(--color-bg-primary);
  border: 2px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}
.qc-label {
  font-family: var(--font-mono);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-tertiary);
  margin-bottom: var(--spacing-sm);
}
.qc-form {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}
.qc-input {
  width: 100%;
  padding: 8px 10px;
  font-size: var(--text-sm);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-base);
  background: var(--color-bg-secondary);
  color: var(--color-text-primary);
  outline: none;
  transition: border-color var(--transition-fast);
}
.qc-input:focus {
  border-color: var(--color-primary);
  background: var(--color-bg-primary);
}
.qc-types {
  display: flex;
  gap: 4px;
}
.qc-type {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
  background: var(--color-bg-secondary);
  color: var(--color-text-tertiary);
  cursor: pointer;
  transition: all var(--transition-fast);
}
.qc-type:hover {
  border-color: var(--color-border-hover);
  color: var(--color-text-secondary);
}
.qc-type.active {
  background: var(--color-text-primary);
  color: var(--color-bg-primary);
  border-color: var(--color-text-primary);
}

/* ── Mini calendar ── */
.mini-cal { padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md); }
.mini-cal .cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0;
  text-align: center;
}
.cal-dow {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  color: var(--color-text-tertiary);
  padding: 4px 0;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.cal-day {
  font-size: 12px;
  padding: 4px 0;
  border-radius: var(--radius-sm);
  color: var(--color-text-primary);
  cursor: default;
  position: relative;
  font-weight: var(--font-medium);
}
.cal-day.other-month {
  color: var(--color-text-tertiary);
  opacity: 0.4;
}
.cal-day.today {
  background: var(--color-primary);
  color: white;
  font-weight: var(--font-bold);
  border-radius: var(--radius-base);
}
.cal-day.has-event::after {
  content: '';
  position: absolute;
  bottom: 1px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  border-radius: var(--radius-full);
  background: var(--color-primary);
}
.cal-day.today.has-event::after {
  background: white;
}
.mini-cal-nav-btn {
  width: 22px;
  height: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-bg-secondary);
  color: var(--color-text-secondary);
  cursor: pointer;
  font-size: 12px;
  transition: all var(--transition-fast);
  text-decoration: none;
}
.mini-cal-nav-btn:hover {
  background: var(--color-bg-hover);
  color: var(--color-text-primary);
}

/* ── Activity feed ── */
.activity-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  border-bottom: 1px solid var(--color-bg-tertiary);
  font-size: var(--text-sm);
}
.activity-item:last-child { border-bottom: none; }

.activity-icon {
  width: 24px;
  height: 24px;
  border-radius: var(--radius-base);
  background: var(--color-bg-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.activity-icon--telegram { background: #dce8f7; }
.activity-icon--task_done { background: #d8eddf; }
.activity-icon--task_new { background: #e0eaff; }
.activity-icon--voice { background: #d8eddf; }

.activity-text {
  flex: 1;
  min-width: 0;
  font-size: 13px;
  color: var(--color-text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.activity-text strong {
  color: var(--color-text-primary);
  font-weight: var(--font-semibold);
}
.activity-time {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-tertiary);
  flex-shrink: 0;
}

/* ── Flash messages ── */
.flash-notice, .flash-alert {
  position: fixed;
  top: var(--spacing-md);
  right: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-base);
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  z-index: var(--z-tooltip);
  animation: flash-in 0.3s ease, flash-out 0.3s ease 3s forwards;
}
.flash-notice {
  background: var(--color-secondary);
  color: white;
}
.flash-alert {
  background: var(--color-danger);
  color: white;
