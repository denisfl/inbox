<% content_for :title, "Inbox — Dashboard" %>

<div class="dash-wrap">

  <%# ── Date stamp ── %>
  <div class="dash-datestamp"><%= Date.current.strftime("%A · %B %-d, %Y") %></div>

  <%# ── Two-column layout ── %>
  <div class="dash-cols">

    <%# ════════ LEFT: tasks + docs ════════ %>
    <div class="dash-main">

      <%# ── Today's Tasks ── %>
      <section class="dash-section">
        <div class="dash-section-head">
          <div class="dash-section-left">
            <svg class="progress-ring-svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="9" fill="none" stroke="var(--color-border)" stroke-width="2.5"/>
              <% total = @tasks_today.size + @tasks_completed_today.size
                 done = @tasks_completed_today.size
                 circumference = 56.5
                 offset = total > 0 ? circumference * (1 - done.to_f / total) : circumference %>
              <circle cx="12" cy="12" r="9" fill="none" stroke="var(--color-primary)" stroke-width="2.5"
                stroke-dasharray="<%= circumference %>" stroke-dashoffset="<%= offset.round(1) %>"
                style="transform:rotate(-90deg);transform-origin:50% 50%"/>
            </svg>
            <h2 class="dash-section-title">Today's Tasks</h2>
            <span class="dash-section-meta"><%= done %> of <%= total %></span>
          </div>
          <%= link_to tasks_path, class: "dash-section-link" do %>All tasks →<% end %>
        </div>

        <%= form_with(url: tasks_path, method: :post, class: "dash-task-add") do |f| %>
          <%= heroicon(:plus, style: 'width: 11px; height: 11px;') %>
          <input type="text" name="task[title]" class="dash-task-add-input" placeholder="Add a task..." autocomplete="off" autofocus>
          <input type="hidden" name="task[due_date]" value="<%= Date.current.to_s %>">
          <input type="hidden" name="redirect_to" value="<%= root_path %>">
        <% end %>

        <div class="task-list">
          <% @tasks_today.each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>
          <% @tasks_completed_today.each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>
          <% if @tasks_today.empty? && @tasks_completed_today.empty? %>
            <%= render "shared/empty_state",
                       icon: :check_circle,
                       title: "No tasks for today" %>
          <% end %>
        </div>
      </section>

      <%# ── Recent Documents ── %>
      <section class="dash-section">
        <div class="dash-section-head">
          <div class="dash-section-left">
            <h2 class="dash-section-title">Recent Documents</h2>
            <span class="dash-section-meta"><%= @sidebar_counts[:documents] %> total</span>
          </div>
          <%= link_to documents_path, class: "dash-section-link" do %>All documents →<% end %>
        </div>

        <% @recent_documents.each do |doc| %>
          <%
            preview_text = nil
            text_block = doc.blocks.find { |b| b.block_type == 'text' }
            if text_block && text_block.content.present?
              begin
                data = JSON.parse(text_block.content)
                raw = data['text'] || data[:text]
                preview_text = raw.truncate(80) if raw.present? && raw != doc.title
              rescue JSON::ParserError
              end
            end
          %>
          <%= link_to edit_document_path(doc), class: "dash-doc" do %>
            <span class="dash-doc-title"><%= doc.title.truncate(50) %></span>
            <% if preview_text %>
              <span class="dash-doc-preview"><%= preview_text %></span>
            <% end %>
            <span class="dash-doc-time"><%= time_ago_short(doc.created_at) %></span>
          <% end %>
        <% end %>

        <% if @recent_documents.empty? %>
          <%= render "shared/empty_state",
                     icon: :document_text,
                     title: "No notes yet",
                     description: "Send something to Telegram or create a new note" %>
        <% end %>
      </section>

    </div><%# .dash-main %>

    <%# ════════ RIGHT: calendar + events + activity ════════ %>
    <div class="dash-aside">

      <%# ── Mini Calendar ── %>
      <section class="dash-section dash-section--aside panel-calendar">
        <div class="dash-section-head">
          <div class="dash-section-left">
            <h2 class="dash-section-title"><%= @cal_date.strftime("%B %Y") %></h2>
          </div>
          <div style="display:flex;gap:3px">
            <%= link_to root_path(cal_month: (@cal_date - 1.month).strftime("%Y-%m")), class: "cal-nav-btn" do %><%= heroicon(:chevron_left, style: 'width: 12px; height: 12px;') %><% end %>
            <%= link_to root_path(cal_month: (@cal_date + 1.month).strftime("%Y-%m")), class: "cal-nav-btn" do %><%= heroicon(:chevron_right, style: 'width: 12px; height: 12px;') %><% end %>
          </div>
        </div>
        <div class="mini-cal">
          <div class="cal-grid">
            <div class="cal-dow">Mo</div>
            <div class="cal-dow">Tu</div>
            <div class="cal-dow">We</div>
            <div class="cal-dow">Th</div>
            <div class="cal-dow">Fr</div>
            <div class="cal-dow">Sa</div>
            <div class="cal-dow">Su</div>

            <%
              first_wday = cal_first_wday(@cal_date)
              days_in_month = @cal_month_end.day
              prev_month_end = @cal_month_start - 1.day
            %>

            <% first_wday.times do |i| %>
              <div class="cal-day other-month"><%= prev_month_end.day - first_wday + i + 1 %></div>
            <% end %>

            <% (1..days_in_month).each do |day| %>
              <%
                is_today = day == @cal_date.day && @cal_month_start.month == Date.current.month && @cal_month_start.year == Date.current.year
                has_event = @cal_event_days.include?(day)
                classes = ["cal-day"]
                classes << "today" if is_today
                classes << "has-event" if has_event
              %>
              <div class="<%= classes.join(' ') %>"><%= day %></div>
            <% end %>

            <% remaining = (7 - (first_wday + days_in_month) % 7) % 7 %>
            <% remaining.times do |i| %>
              <div class="cal-day other-month"><%= i + 1 %></div>
            <% end %>
          </div>
        </div>
      </section>

      <%# ── Events ── %>
      <section class="dash-section dash-section--aside">
        <div class="dash-section-head">
          <div class="dash-section-left">
            <h2 class="dash-section-title">Events</h2>
          </div>
          <%= link_to new_calendar_event_path, class: "dash-section-link" do %>+ Add<% end %>
        </div>

        <% has_any_events = @events_today.any? || @events_tomorrow.any? || @events_week.any? || @events_next_week.any? %>

        <% if @events_today.any? %>
          <div class="dash-ev-group">Today</div>
          <% @events_today.each do |event| %>
            <div class="dash-ev">
              <div class="dash-ev-bar" style="background:<%= event.display_color %>"></div>
              <div class="dash-ev-time"><%= event.time_label %></div>
              <div class="dash-ev-body">
                <div class="dash-ev-title"><%= event.all_day? ? "All day: #{event.title}" : event.title %></div>
                <% if event.duration_label %>
                  <div class="dash-ev-sub"><%= event.duration_label %></div>
                <% end %>
              </div>
              <% badge = event_source_badge(event) %>
              <span class="<%= badge[:class] %>"><%= badge[:text] %></span>
            </div>
          <% end %>
        <% end %>

        <% if @events_tomorrow.any? %>
          <div class="dash-ev-group">Tomorrow</div>
          <% @events_tomorrow.each do |event| %>
            <div class="dash-ev">
              <div class="dash-ev-bar" style="background:<%= event.display_color %>"></div>
              <div class="dash-ev-time"><%= event.time_label %></div>
              <div class="dash-ev-body">
                <div class="dash-ev-title"><%= event.all_day? ? "All day: #{event.title}" : event.title %></div>
                <% if event.duration_label %>
                  <div class="dash-ev-sub"><%= event.duration_label %></div>
                <% end %>
              </div>
              <% badge = event_source_badge(event) %>
              <span class="<%= badge[:class] %>"><%= badge[:text] %></span>
            </div>
          <% end %>
        <% end %>

        <% if @events_week.any? %>
          <div class="dash-ev-group">This week</div>
          <% @events_week.each do |event| %>
            <div class="dash-ev">
              <div class="dash-ev-bar" style="background:<%= event.display_color %>"></div>
              <div class="dash-ev-time"><%= event.time_label %></div>
              <div class="dash-ev-body">
                <div class="dash-ev-title"><%= event.title %></div>
                <div class="dash-ev-sub"><%= event.duration_label %><%= " · #{event.starts_at.strftime('%a %b %-d')}" %></div>
              </div>
              <% badge = event_source_badge(event) %>
              <span class="<%= badge[:class] %>"><%= badge[:text] %></span>
            </div>
          <% end %>
        <% end %>

        <% if @events_next_week.any? %>
          <div class="dash-ev-group">Next week</div>
          <% @events_next_week.each do |event| %>
            <div class="dash-ev">
              <div class="dash-ev-bar" style="background:<%= event.display_color %>"></div>
              <div class="dash-ev-time"><%= event.time_label %></div>
              <div class="dash-ev-body">
                <div class="dash-ev-title"><%= event.title %></div>
                <div class="dash-ev-sub"><%= event.duration_label %><%= " · #{event.starts_at.strftime('%a %b %-d')}" %></div>
              </div>
              <% badge = event_source_badge(event) %>
              <span class="<%= badge[:class] %>"><%= badge[:text] %></span>
            </div>
          <% end %>
        <% end %>

        <% unless has_any_events %>
          <%= render "shared/empty_state",
                     icon: :calendar,
                     title: "No events scheduled" %>
        <% end %>
      </section>

      <%# ── Activity ── %>
      <section class="dash-section dash-section--aside panel-activity">
        <div class="dash-section-head">
          <div class="dash-section-left">
            <h2 class="dash-section-title">Activity</h2>
          </div>
        </div>
        <% @activities.each do |act| %>
          <div class="dash-act">
            <div class="dash-act-dot dash-act-dot--<%= act[:icon_type] %>"></div>
            <div class="dash-act-text"><%= act[:text].html_safe %></div>
            <div class="dash-act-time"><%= time_ago_short(act[:time]) %></div>
          </div>
        <% end %>
        <% if @activities.empty? %>
          <%= render "shared/empty_state",
                     icon: :chart_bar,
                     title: "No activity yet" %>
        <% end %>
      </section>

    </div><%# .dash-aside %>
  </div><%# .dash-cols %>
</div><%# .dash-wrap %>

<%# ── Flash messages ── %>
<% if flash[:notice] %>
  <div class="flash-notice"><%= flash[:notice] %></div>
<% end %>
<% if flash[:alert] %>
  <div class="flash-alert"><%= flash[:alert] %></div>
<% end %>

<style>
/* ═══════════════════════════════════════════════════════════════════════════
   DASHBOARD STYLES — flat, type-driven layout
   ═══════════════════════════════════════════════════════════════════════════ */

/* ── Wrapper ── */
.dash-wrap {
  margin: 0 auto;
  padding: 36px 40px 60px;
  flex: 1;
  overflow-x: hidden;
  overflow-y: auto;
  background: var(--color-bg-primary);
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-lg);
}

/* ── Date stamp ── */
.dash-datestamp {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-quaternary);
  margin-bottom: 32px;
}

/* ── Two-column grid ── */
.dash-cols {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 260px;
  gap: 0 56px;
  align-items: start;
}
.dash-main { display: flex; flex-direction: column; min-width: 0; }
.dash-aside { display: flex; flex-direction: column; min-width: 0; }

/* ── Section ── */
.dash-section {
  padding-bottom: 40px;
  margin-bottom: 8px;
  border-bottom: 1px solid var(--color-border-soft);
  min-width: 0;
}
.dash-section:last-child { border-bottom: none; }
.dash-section--aside {
  padding-bottom: 28px;
  margin-bottom: 4px;
}

.dash-section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16px;
}
.dash-section-left {
  display: flex;
  align-items: center;
  gap: 10px;
}
.progress-ring-svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}
.dash-section-title {
  font-family: var(--font-display);
  font-size: 19px;
  font-weight: 900;
  color: var(--color-text-primary);
  letter-spacing: -0.025em;
  line-height: 1;
}
.dash-section-meta {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-text-quaternary);
}
.dash-section-link {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-primary);
  text-decoration: none;
  white-space: nowrap;
  transition: color var(--transition-fast);
}
.dash-section-link:hover {
  color: var(--color-primary-hover);
  text-decoration: underline;
}

/* ── Task add ── */
.dash-task-add {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 0;
  border-bottom: 1px solid var(--color-border-soft);
  color: var(--color-text-quaternary);
  margin-bottom: 2px;
}
.dash-task-add-input {
  flex: 1;
  border: none;
  background: transparent;
  font: 14px var(--font-sans);
  color: var(--color-text-primary);
  outline: none;
}
.dash-task-add-input::placeholder {
  color: var(--color-text-quaternary);
}

/* ── Task list (dashboard compact overrides) ── */
.task-list .task-item-actions {
  display: none;
}

/* ── Doc row ── */
.dash-doc {
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding: 10px 0;
  border-bottom: 1px solid var(--color-border-soft);
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  border-radius: 4px;
  margin: 0 -6px;
  padding-left: 6px;
  padding-right: 6px;
  transition: background var(--transition-fast);
  min-width: 0;
}
.dash-doc:last-child { border-bottom: none; }
.dash-doc:hover { background: var(--color-bg-hover); }
.dash-doc-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
  max-width: 52%;
}
.dash-doc-preview {
  font-size: 13px;
  color: var(--color-text-quaternary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}
.dash-doc-time {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-text-quaternary);
  flex-shrink: 0;
  margin-left: auto;
  padding-left: 12px;
}

/* ── Event group label ── */
.dash-ev-group {
  font-family: var(--font-mono);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-text-quaternary);
  padding: 10px 0 4px;
}
.dash-ev-group:first-of-type { padding-top: 0; }

/* ── Event row ── */
.dash-ev {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0;
  border-bottom: 1px solid var(--color-border-soft);
  cursor: pointer;
}
.dash-ev:last-of-type { border-bottom: none; }
.dash-ev:hover .dash-ev-title { color: var(--color-primary); }
.dash-ev-bar {
  width: 3px;
  border-radius: 2px;
  align-self: stretch;
  min-height: 20px;
  flex-shrink: 0;
}
.dash-ev-time {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--color-text-tertiary);
  min-width: 36px;
  flex-shrink: 0;
}
.dash-ev-body { flex: 1; min-width: 0; overflow: hidden; }
.dash-ev-title {
  font-size: 13.5px;
  font-weight: 500;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: color var(--transition-fast);
}
.dash-ev-sub {
  font-size: 11.5px;
  color: var(--color-text-quaternary);
  margin-top: 1px;
}

/* Event source badges (reused from tl-src) */
.tl-src {
  font-family: var(--font-mono);
  font-size: 9.5px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}
.tl-src.gcal {
  background: var(--color-blue-soft);
  color: var(--color-blue);
  border: 1px solid color-mix(in srgb, var(--color-blue) 25%, var(--color-border));
}
.tl-src.manual {
  background: var(--color-bg-tertiary);
  color: var(--color-text-tertiary);
  border: 1px solid var(--color-border);
}
.tl-src.ical {
  background: var(--color-blue-soft);
  color: var(--color-blue);
  border: 1px solid color-mix(in srgb, var(--color-blue) 25%, var(--color-border));
}

/* ── Activity ── */
.dash-act {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
  border-bottom: 1px solid var(--color-border-soft);
  font-size: var(--text-xs);
  min-width: 0;
}
.dash-act:last-child { border-bottom: none; }
.dash-act-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.dash-act-dot--telegram,
.dash-act-dot--task_new,
.dash-act-dot--calendar { background: var(--color-blue); }
.dash-act-dot--task_done { background: var(--color-primary); }
.dash-act-dot--voice { background: var(--color-accent); }
.dash-act-text {
  flex: 1;
  color: var(--color-text-secondary);
  font-size: var(--text-xs);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dash-act-text strong {
  color: var(--color-text-primary);
  font-weight: 600;
}
.dash-act-time {
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--color-text-quaternary);
  flex-shrink: 0;
}

/* ── Mini calendar ── */
.mini-cal .cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 0;
  text-align: center;
  margin-top: 8px;
}
.cal-dow {
  font-size: 9.5px;
  font-weight: 700;
  color: var(--color-text-quaternary);
  padding: 0 0 5px;
  text-transform: uppercase;
}
.cal-day {
  font-size: 12px;
  padding: 4px 1px;
  border-radius: 4px;
  color: var(--color-text-secondary);
  cursor: pointer;
  position: relative;
  transition: background var(--transition-fast);
}
.cal-day:hover { background: var(--color-bg-secondary); }
.cal-day.other-month { color: var(--color-text-quaternary); }
.cal-day.today {
  background: var(--color-primary);
  color: white;
  font-weight: var(--font-bold);
  border-radius: 6px;
}
.cal-day.has-event::after {
  content: '';
  position: absolute;
  bottom: 1px;
  left: 50%;
  transform: translateX(-50%);
  width: 3px;
  height: 3px;
  border-radius: var(--radius-full);
  background: var(--color-primary);
}
.cal-day.today.has-event::after {
  background: color-mix(in srgb, var(--color-bg-primary) 60%, transparent);
}
.cal-nav-btn {
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: var(--color-bg-secondary);
  color: var(--color-text-tertiary);
  cursor: pointer;
  transition: background var(--transition-fast);
  text-decoration: none;
}
.cal-nav-btn:hover { background: var(--color-border); }

/* ── Flash messages ── */
.flash-notice, .flash-alert {
  position: fixed;
  top: var(--spacing-md);
  right: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-base);
  font-size: var(--text-sm);
  font-weight: var(--font-medium);
  z-index: var(--z-tooltip);
  animation: flash-in 0.3s ease, flash-out 0.3s ease 3s forwards;
}
.flash-notice { background: var(--color-secondary); color: white; }
.flash-alert { background: var(--color-danger); color: white; }
@keyframes flash-in {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes flash-out {
  from { opacity: 1; }
  to { opacity: 0; }
}

/* ── Responsive ── */
@media (max-width: 1100px) {
  .dash-cols {
    grid-template-columns: 100%;
  }
  .dash-aside {
    order: -1;
  }
  .panel-activity {
    display: none;
  }
}

@media (max-width: 768px) {
  .dash-wrap {
    padding: 20px 16px 40px;
  }
  .panel-calendar {
    display: none;
  }
}
</style>
