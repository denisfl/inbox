<% content_for :title, "Edit Task — Inbox" %>

<div class="task-form-page">
  <div class="task-form-container">
    <header class="task-form-header">
      <%= back_link(tasks_path, "Tasks") %>
      <h1 class="task-form-title">Edit Task</h1>
    </header>

    <%= render "form", task: @task, url: task_path(@task), method: :patch, submit_label: "Save" %>
  </div>
</div>

