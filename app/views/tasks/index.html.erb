<% content_for :title, "Tasks — Inbox" %>

<div class="tasks-page">
  <div class="tasks-container">
    <%# Header %>
    <header class="tasks-header">
      <h1 class="tasks-page-title">
        <%= heroicon(:clipboard, style: 'width: 1.5rem; height: 1.5rem;') %>
        Tasks
      </h1>

      <%= link_to new_task_path, class: "btn btn-primary btn-sm" do %>
        <%= heroicon(:plus, style: 'width: 1rem; height: 1rem;') %>
        New Task
      <% end %>
    </header>

    <%# Filter Tabs %>
    <nav class="tasks-filters">
      <%= link_to tasks_path(filter: "today"), class: "tasks-filter-tab #{'tasks-filter-tab--active' if @filter == 'today'}" do %>
        Today
        <% if @today_count > 0 %><span class="tasks-filter-count"><%= @today_count %></span><% end %>
      <% end %>
      <%= link_to tasks_path(filter: "upcoming"), class: "tasks-filter-tab #{'tasks-filter-tab--active' if @filter == 'upcoming'}" do %>
        Upcoming
      <% end %>
      <%= link_to tasks_path(filter: "inbox"), class: "tasks-filter-tab #{'tasks-filter-tab--active' if @filter == 'inbox'}" do %>
        Inbox
        <% if @inbox_count > 0 %><span class="tasks-filter-count"><%= @inbox_count %></span><% end %>
      <% end %>
      <% if @overdue_count > 0 %>
        <%= link_to tasks_path(filter: "overdue"), class: "tasks-filter-tab tasks-filter-tab--overdue #{'tasks-filter-tab--active' if @filter == 'overdue'}" do %>
          Overdue
          <span class="tasks-filter-count tasks-filter-count--danger"><%= @overdue_count %></span>
        <% end %>
      <% end %>
      <%= link_to tasks_path(filter: "all"), class: "tasks-filter-tab #{'tasks-filter-tab--active' if @filter == 'all'}" do %>
        All
      <% end %>
      <%= link_to tasks_path(filter: "completed"), class: "tasks-filter-tab #{'tasks-filter-tab--active' if @filter == 'completed'}" do %>
        Completed
      <% end %>
    </nav>

    <%# Tag filter bar %>
    <% if @selected_tags.any? || Tag.any? %>
      <%= render partial: "shared/tag_filter_bar", locals: {
        selected_tags: @selected_tags,
        base_path: tasks_path,
        preserve: { filter: @filter }.compact_blank
      } %>
    <% end %>

    <%# Quick Add Form %>
    <div class="task-quick-add">
      <%= form_with(url: tasks_path, method: :post, class: "task-quick-add-form") do |f| %>
        <span class="task-quick-add-icon">
          <%= heroicon(:plus, style: 'width: 1rem; height: 1rem;') %>
        </span>
        <%= f.text_field :title, name: "task[title]", class: "task-quick-add-input", placeholder: "Add task...", autocomplete: "off" %>
        <% if @filter == "today" %>
          <%= f.hidden_field :due_date, name: "task[due_date]", value: Date.current.to_s %>
        <% end %>
      <% end %>
    </div>

    <%# Task List %>
    <div class="tasks-list">
      <% if @tasks.any? %>
        <% if @filter == "upcoming" %>
          <%# Group upcoming tasks by date %>
          <% @tasks.group_by(&:due_date).each do |date, tasks| %>
            <div class="tasks-day-group">
              <div class="tasks-day-header">
                <span class="tasks-day-name"><%= l(date, format: "%A") %></span>
                <span class="tasks-day-date"><%= date.strftime("%d.%m.%Y") %></span>
              </div>
              <% tasks.each do |task| %>
                <%= render "tasks/task", task: task %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <% @tasks.each do |task| %>
            <%= render "tasks/task", task: task %>
          <% end %>
        <% end %>
      <% else %>
        <%
          empty_title = case @filter
                        when "today"     then "No tasks for today"
                        when "upcoming"  then "No upcoming tasks"
                        when "inbox"     then "All inbox items sorted"
                        when "overdue"   then "No overdue tasks"
                        when "completed" then "No completed tasks yet"
                        else "No tasks"
                        end
        %>
        <% task_actions = capture do %>
          <div class="empty-state-actions">
            <%= link_to "Create task", new_task_path, class: "btn btn-primary" %>
          </div>
        <% end %>
        <%= render "shared/empty_state",
                   icon: :check_circle,
                   title: empty_title,
                   actions: task_actions %>
      <% end %>
    </div>
  </div>
</div>

<style>
  /* ── Page layout ─────────────────────────────────────────────────── */
  .tasks-page {
    max-width: 800px;
    margin: 0 auto;
      border-radius: var(--radius-sm);
      box-shadow: var(--shadow-lg);
  }

  .tasks-container {
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  /* ── Header ──────────────────────────────────────────────────────── */
  .tasks-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .tasks-page-title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  /* ── Filter tabs ─────────────────────────────────────────────────── */
  .tasks-filters {
    display: flex;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm) var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tasks-filter-tab {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-base);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .tasks-filter-tab:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
  }

  .tasks-filter-tab--active {
    background: color-mix(in srgb, var(--color-primary) 10%, var(--color-bg-primary));
    color: var(--color-primary);
    font-weight: var(--font-medium);
  }

  .tasks-filter-tab--overdue {
    color: var(--color-danger);
  }

  .tasks-filter-count {
    font-size: var(--text-xs);
    background: var(--color-bg-tertiary);
    padding: 1px var(--spacing-xs);
    border-radius: var(--radius-full);
    font-weight: var(--font-medium);
    min-width: 1.2em;
    text-align: center;
  }

  .tasks-filter-count--danger {
    background: color-mix(in srgb, var(--color-danger) 15%, var(--color-bg-primary));
    color: var(--color-danger);
  }

  /* ── Task list ───────────────────────────────────────────────────── */
  .tasks-list {
    padding: var(--spacing-xs) 0;
  }

  /* Task item overrides for tasks page (wider padding) */
  .tasks-list .task-item {
    padding: var(--spacing-sm) var(--spacing-lg);
  }

  /* ── Day groups (upcoming view) ──────────────────────────────────── */
  .tasks-day-group {
    margin-bottom: var(--spacing-xs);
  }

  .tasks-day-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-lg);
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .tasks-day-name {
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    text-transform: capitalize;
  }

  .tasks-day-date {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* ── Quick Add ─────────────────────────────────────────────────── */
  .task-quick-add {
    padding: var(--spacing-sm) var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .task-quick-add-form {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .task-quick-add-icon {
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .task-quick-add-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    padding: var(--spacing-xs) 0;
  }

  .task-quick-add-input::placeholder {
    color: var(--color-text-tertiary);
  }

  /* ── Mobile ──────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .tasks-header {
      padding: var(--spacing-sm) var(--spacing-md);
    }

    .tasks-filters {
      padding: var(--spacing-xs) var(--spacing-sm);
    }

    .tasks-list .task-item {
      padding: var(--spacing-sm) var(--spacing-md);
    }

    .tasks-day-header {
      padding: var(--spacing-xs) var(--spacing-md);
    }

    .task-quick-add {
      padding: var(--spacing-sm) var(--spacing-md);
    }
  }
</style>
