<%= form_with(model: task, url: url, method: method, class: "task-form") do |f| %>
  <% if task.errors.any? %>
    <div class="task-form-errors">
      <strong><%= pluralize(task.errors.count, "ошибка") %>:</strong>
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="task-field">
    <%= f.label :title, "Название", class: "task-field-label" %>
    <%= f.text_field :title, class: "input", placeholder: "Что нужно сделать?", autofocus: true %>
  </div>

  <div class="task-field">
    <%= f.label :description, "Описание (Markdown)", class: "task-field-label" %>
    <%= f.text_area :description, class: "input task-description-input", placeholder: "Детали задачи...", rows: 4 %>
  </div>

  <div class="task-field-group">
    <div class="task-field">
      <%= f.label :due_date, "Дата", class: "task-field-label" %>
      <%= f.date_field :due_date, class: "input" %>
    </div>
    <div class="task-field">
      <%= f.label :due_time, "Время", class: "task-field-label" %>
      <%= f.time_field :due_time, class: "input" %>
    </div>
  </div>

  <div class="task-field-group">
    <div class="task-field">
      <%= f.label :priority, "Приоритет", class: "task-field-label" %>
      <%= f.select :priority,
            [["Закреплённая", "pinned"], ["Высокий", "high"], ["Обычный", "mid"], ["Низкий", "low"]],
            {}, class: "input" %>
    </div>
    <div class="task-field">
      <%= f.label :recurrence_rule, "Повторение", class: "task-field-label" %>
      <%= f.select :recurrence_rule,
            [["Не повторять", ""], ["Ежедневно", "daily"], ["Еженедельно", "weekly"], ["Ежемесячно", "monthly"], ["Ежегодно", "yearly"]],
            { include_blank: false }, class: "input" %>
    </div>
  </div>

  <div class="task-form-actions">
    <%= f.submit submit_label, class: "btn btn-success" %>
    <%= link_to "Отмена", tasks_path, class: "btn btn-secondary" %>
  </div>
<% end %>
