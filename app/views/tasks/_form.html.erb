<%= form_with(model: task, url: url, method: method, class: "task-form",
      data: { controller: "task-form" }) do |f| %>
  <% if task.errors.any? %>
    <div class="task-form-errors">
      <strong><%= pluralize(task.errors.count, "error") %>:</strong>
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="task-field">
    <%= f.label :title, "Title", class: "task-field-label" %>
    <%= f.text_field :title, class: "input", placeholder: "What needs to be done?", autofocus: true %>
  </div>

  <div class="task-field">
    <%= f.label :description, "Description", class: "task-field-label" %>
    <%= f.rich_text_area :description %>
  </div>

  <%# Date shortcuts %>
  <div class="date-shortcuts">
    <button type="button" class="date-shortcut"
            data-action="click->task-form#setToday">Today</button>
    <button type="button" class="date-shortcut"
            data-action="click->task-form#setTomorrow">Tomorrow</button>
    <button type="button" class="date-shortcut"
            data-action="click->task-form#setDaysAhead"
            data-days="3">+3 days</button>
    <button type="button" class="date-shortcut"
            data-action="click->task-form#setDaysAhead"
            data-days="7">+7 days</button>
  </div>

  <div class="task-field-group">
    <div class="task-field">
      <%= f.label :due_date, "Date", class: "task-field-label" %>
      <%= f.date_field :due_date, class: "input" %>
    </div>
    <div class="task-field">
      <%= f.label :due_time, "Time", class: "task-field-label" %>
      <div class="time-combobox" data-controller="time-combobox">
        <input type="text"
               class="input time-combobox__input"
               placeholder="9:00 AM"
               autocomplete="off"
               value="<%= task.due_time&.strftime("%-I:%M %p") %>"
               data-time-combobox-target="input"
               data-action="focus->time-combobox#onFocus
                            blur->time-combobox#onBlur
                            input->time-combobox#onInput
                            keydown->time-combobox#onKeydown">
        <input type="hidden"
               name="task[due_time]"
               value="<%= task.due_time&.strftime("%H:%M") %>"
               data-time-combobox-target="hidden">
        <div class="time-combobox__dropdown" data-time-combobox-target="dropdown"></div>
      </div>
    </div>
  </div>

  <div class="task-field-group">
    <div class="task-field">
      <%= f.label :priority, "Priority", class: "task-field-label" %>
      <%= f.select :priority,
            [["Pinned", "pinned"], ["High", "high"], ["Normal", "mid"], ["Low", "low"]],
            {}, class: "input" %>
    </div>
    <div class="task-field">
      <%= f.label :recurrence_rule, "Recurrence", class: "task-field-label" %>
      <%= f.select :recurrence_rule,
            [["No repeat", ""], ["Daily", "daily"], ["Weekly", "weekly"], ["Monthly", "monthly"], ["Yearly", "yearly"]],
            { include_blank: false }, class: "input" %>
    </div>
  </div>

  <% if task.persisted? %>
    <div class="task-field">
      <label class="task-field-label">Tags</label>
      <div class="task-tag-input">
        <%= render "shared/tag_input", entity_type: "task", entity: task %>
      </div>
    </div>
  <% end %>

  <div class="task-form-actions">
    <%= f.submit submit_label, class: "btn btn-primary" %>
    <%= link_to "Cancel", tasks_path, class: "btn btn-secondary" %>
  </div>
<% end %>
