<%= tag.div id: dom_id(task), class: "task-item #{'task-item--completed' if task.completed?} #{'task-item--overdue' if task.overdue?} task-item--priority-#{task.priority}" do %>
  <div class="task-item-left">
    <%= button_to toggle_task_path(task), method: :patch, class: "task-checkbox-btn", data: { turbo: true } do %>
      <span class="task-checkbox <%= 'task-checkbox--checked' if task.completed? %>">
        <% if task.completed? %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="task-check-icon">
            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
          </svg>
        <% end %>
      </span>
    <% end %>
    <% if task.priority == "pinned" %>
      <span class="task-pin-icon" title="Закреплена">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="width: 12px; height: 12px;">
          <path d="M8.5 1.5a.5.5 0 0 0-1 0v4.146L4.354 8.793a.5.5 0 0 0 0 .707l2.146 2.146V15.5a.5.5 0 0 0 1 0v-3.854l2.146-2.146a.5.5 0 0 0 0-.707L6.5 5.646V1.5Z"/>
        </svg>
      </span>
    <% end %>
  </div>

  <div class="task-item-content">
    <div class="task-item-row">
      <span class="task-item-title"><%= task.title %></span>
      <% if task.recurring? %>
        <span class="task-recurrence-badge" title="<%= task.recurrence_rule %>">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width: 12px; height: 12px;">
            <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H4.598a.75.75 0 0 0-.75.75v3.634a.75.75 0 0 0 1.5 0v-2.134l.228.228a7 7 0 0 0 11.72-3.133.75.75 0 0 0-1.449-.39Zm-10.624-2.85a5.5 5.5 0 0 1 9.201-2.465l.312.31H11.77a.75.75 0 0 0 0 1.5h3.634a.75.75 0 0 0 .75-.75V3.535a.75.75 0 0 0-1.5 0v2.134l-.228-.228A7 7 0 0 0 2.706 8.574a.75.75 0 0 0 1.449.39l.533-1.39Z" clip-rule="evenodd" />
          </svg>
        </span>
      <% end %>
    </div>

    <% if task.due_date.present? || task.description.present? %>
      <div class="task-item-meta">
        <% if task.due_date.present? %>
          <span class="task-due-badge <%= 'task-due-badge--overdue' if task.overdue? %> <%= 'task-due-badge--today' if task.due_today? %>">
            <%= task.due_date.strftime("%d.%m") %>
            <% if task.due_time.present? %>
              <span class="task-due-time"><%= task.due_time.strftime("%H:%M") %></span>
            <% end %>
          </span>
        <% end %>
        <% if task.description.present? %>
          <span class="task-has-desc" title="Есть описание">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" style="width: 12px; height: 12px;">
              <path d="M2 4.5A2.5 2.5 0 0 1 4.5 2h7A2.5 2.5 0 0 1 14 4.5v7a2.5 2.5 0 0 1-2.5 2.5h-7A2.5 2.5 0 0 1 2 11.5v-7ZM4 5.75A.75.75 0 0 1 4.75 5h6.5a.75.75 0 0 1 0 1.5h-6.5A.75.75 0 0 1 4 5.75ZM4.75 7.5a.75.75 0 0 0 0 1.5h6.5a.75.75 0 0 0 0-1.5h-6.5ZM4 10.75a.75.75 0 0 1 .75-.75h2.5a.75.75 0 0 1 0 1.5h-2.5a.75.75 0 0 1-.75-.75Z"/>
            </svg>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="task-item-actions">
    <%= link_to edit_task_path(task), class: "task-action-btn", title: "Редактировать" do %>
      <%= heroicon(:pencil, style: 'width: 1rem; height: 1rem;') %>
    <% end %>
    <%= button_to task_path(task), method: :delete, class: "task-action-btn task-action-btn--danger", title: "Удалить",
        data: { turbo_confirm: "Удалить задачу «#{task.title}»?" } do %>
      <%= heroicon(:trash, style: 'width: 1rem; height: 1rem;') %>
    <% end %>
  </div>
<% end %>
