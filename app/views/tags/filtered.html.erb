<% content_for :title, "#{@selected_tags.map { |t| '#' + t.name }.join(' + ')} — Inbox" %>

<div class="tag-detail-page">
  <header class="tag-detail-header">
    <%= back_link(tags_path, "Tags") %>
    <h1 class="tag-detail-title">
      <% @selected_tags.each do |tag| %>
        <span class="tag-filter-pill" style="font-size: var(--text-base);">
          <%= render "shared/tag", tag: tag %>
        </span>
      <% end %>
    </h1>
  </header>

  <%# Tag filter bar for adding/removing tags %>
  <%= render partial: "shared/tag_filter_bar", locals: {
    selected_tags: @selected_tags,
    base_path: tags_path,
    preserve: {}
  } %>

  <%= render "shared/tagged_items",
             documents: @documents,
             tasks: @tasks,
             calendar_events: @calendar_events %>

  <% if @documents.empty? && @tasks.empty? && @calendar_events.empty? %>
    <%= render "shared/empty_state",
               icon: :funnel,
               title: "No items match all selected tags",
               description: "Try removing a tag filter to broaden the results.",
               actions: capture { content_tag(:div, link_to("Clear all tags", tags_path, class: "btn btn-secondary"), class: "empty-state-actions") } %>
  <% end %>
</div>
