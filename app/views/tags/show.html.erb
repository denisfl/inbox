<% content_for :title, "##{@tag.name} — Inbox" %>

<div class="tag-detail-page">
  <header class="tag-detail-header">
    <%= back_link(tags_path, "Tags") %>
    <h1 class="tag-detail-title">
      <%= render "shared/tag", tag: @tag %>
    </h1>
  </header>

  <% if @documents.any? %>
    <section class="tag-section">
      <h2 class="tag-section-title">Documents (<%= @documents.count %>)</h2>
      <div class="documents-grid">
        <%= render partial: "documents/card", collection: @documents, as: :document %>
      </div>
    </section>
  <% end %>

  <% if @tasks.any? %>
    <section class="tag-section">
      <h2 class="tag-section-title">Tasks (<%= @tasks.count %>)</h2>
      <div class="task-list">
        <% @tasks.each do |task| %>
          <%= render partial: "tasks/task", locals: { task: task } %>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @calendar_events.any? %>
    <section class="tag-section">
      <h2 class="tag-section-title">Events (<%= @calendar_events.count %>)</h2>
      <div class="tag-events-list">
        <% @calendar_events.each do |ev| %>
          <div class="tag-event-item">
            <div class="tag-event-color" style="background: <%= ev.display_color %>;"></div>
            <div class="tag-event-info">
              <div class="tag-event-title"><%= ev.title %></div>
              <div class="tag-event-time">
                <%= ev.starts_at.strftime("%-d %b %Y") %>
                <% unless ev.all_day? %>
                  · <%= ev.starts_at.strftime("%-H:%M") %>
                <% end %>
              </div>
            </div>
            <% if ev.local? %>
              <%= link_to edit_calendar_event_path(ev), class: "tag-event-edit" do %>
                <%= heroicon(:pencil, style: 'width: 12px; height: 12px;') %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <% if @documents.empty? && @tasks.empty? && @calendar_events.empty? %>
    <%= render "shared/empty_state",
               icon: :tag,
               title: "No items with this tag",
               description: "Documents and tasks tagged with <strong>##{@tag.name}</strong> will appear here.".html_safe %>
  <% end %>
</div>
