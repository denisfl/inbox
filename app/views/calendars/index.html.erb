<% content_for :title, "Calendar — Inbox" %>

<div class="calendar-page" data-controller="calendar">

  <%# ── Top bar ─────────────────────────────────────────────────────── %>
  <div class="calendar-topbar">
    <div class="calendar-topbar-left">
      <%= link_to calendar_path(date: Date.today, view: @view_mode, filter: @filter), class: "btn btn-sm" do %>
        Today
      <% end %>

      <%# View mode switcher %>
      <div class="view-mode-switcher">
        <% %w[agenda week month].each do |mode| %>
          <%= link_to calendar_path(date: params[:date], filter: params[:filter], view: mode),
                class: "view-mode-btn #{'view-mode-btn--active' if @view_mode == mode}" do %>
            <%= mode.capitalize %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="calendar-topbar-actions">

      <%# Import .ical %>
      <button type="button" class="btn btn-sm btn-secondary" onclick="document.getElementById('ical-import-input').click()">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 1rem; height: 1rem;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
        </svg>
        <span class="topbar-btn-label">Import</span>
      </button>
      <div style="display:none">
        <%= form_with url: import_ical_path, method: :post, multipart: true, id: "ical-import-form" do %>
          <%= file_field_tag :ical_file, id: "ical-import-input", accept: ".ics,text/calendar",
                onchange: "this.form.submit()" %>
        <% end %>
      </div>

      <%# New Event %>
      <%= link_to new_calendar_event_path(date: @view_date), class: "btn btn-sm btn-primary" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width: 1rem; height: 1rem;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        <span class="topbar-btn-label">New Event</span>
      </button>
      <% end %>
    </div>
  </div>

  <div class="calendar-layout">

    <%# ── Left: Mini-month ────────────────────────────────────────────── %>
    <aside class="calendar-sidebar">
      <%# Navigation arrows %>
      <div class="mini-month-header">
        <%= link_to calendar_path(date: (@month_start - 1.month).to_s),
              class: "mini-month-nav-btn", "aria-label": "Previous month" do %>
          ‹
        <% end %>
        <span class="mini-month-title"><%= @month_start.strftime("%B %Y") %></span>
        <%= link_to calendar_path(date: (@month_start + 1.month).to_s),
              class: "mini-month-nav-btn", "aria-label": "Next month" do %>
          ›
        <% end %>
      </div>

      <%# Day-of-week headers %>
      <div class="mini-month-grid">
        <% %w[Mo Tu We Th Fr Sa Su].each do |day| %>
          <div class="mini-month-dow"><%= day %></div>
        <% end %>

        <%# Blank cells before month start %>
        <% ((@month_start.wday - 1) % 7).times do %>
          <div class="mini-month-cell mini-month-cell--empty"></div>
        <% end %>

        <%# Days of the month %>
        <% (@month_start..@month_end).each do |day| %>
          <%
            is_today    = day == Date.today
            is_selected = day == @view_date
            has_content = @days_with_content.include?(day)
            classes = ["mini-month-cell"]
            classes << "mini-month-cell--today"    if is_today
            classes << "mini-month-cell--selected" if is_selected
            classes << "mini-month-cell--has-events" if has_content
          %>
          <%= link_to calendar_path(date: day.to_s),
                class: classes.join(" "),
                "data-calendar-target": "miniDay",
                "data-date": day.to_s do %>
            <%= day.day %>
            <% if has_content %>
              <span class="mini-month-dot"></span>
            <% end %>
          <% end %>
        <% end %>
      </div>

      <%# Quick stats %>
      <div class="calendar-sidebar-stats">
        <div class="calendar-stat">
          <span class="calendar-stat-value"><%= CalendarEvent.today.count %></span>
          <span class="calendar-stat-label">today</span>
        </div>
        <div class="calendar-stat">
          <span class="calendar-stat-value"><%= CalendarEvent.this_week.count %></span>
          <span class="calendar-stat-label">this week</span>
        </div>
      </div>

      <%# Filter tabs %>
      <div class="calendar-filter-tabs">
        <%
          filter_options = [
            ["events", "Events"],
            ["tasks", "Tasks"],
            ["notes", "Notes"],
            ["all", "All"]
          ]
        %>
        <% filter_options.each do |value, label| %>
          <%= link_to calendar_path(date: params[:date], filter: value, view: @view_mode),
                class: "calendar-filter-tab #{'calendar-filter-tab--active' if @filter == value}" do %>
            <%= label %>
          <% end %>
        <% end %>
      </div>
    </aside>

    <%# ── Right: Content area (view-mode dependent) ─────────────────── %>
    <section class="calendar-content">

      <% if @view_mode == "week" %>
        <%# ── WEEK VIEW ── %>
        <div class="week-view">
          <%# Navigation %>
          <div class="week-nav">
            <%= link_to calendar_path(date: (@range_start - 7.days), view: "week", filter: @filter),
                  class: "mini-month-nav-btn", "aria-label": "Previous week" do %>‹<% end %>
            <span class="week-nav-title">
              <%= @range_start.strftime("%-d %b") %> — <%= @range_end.strftime("%-d %b %Y") %>
            </span>
            <%= link_to calendar_path(date: (@range_start + 7.days), view: "week", filter: @filter),
                  class: "mini-month-nav-btn", "aria-label": "Next week" do %>›<% end %>
          </div>

          <%# Day columns %>
          <div class="week-grid">
            <% @week_days.each do |day| %>
              <% is_today = day == Date.today %>
              <div class="week-day-col">
                <div class="week-day-header <%= 'week-day-header--today' if is_today %>">
                  <span class="week-day-name"><%= day.strftime("%a") %></span>
                  <span class="week-day-num"><%= day.day %></span>
                </div>
                <div class="week-day-events">
                  <% (@week_events_by_day[day] || []).each do |entry| %>
                    <% if entry[:type] == :event %>
                      <% ev = entry[:record] %>
                      <div class="week-event" style="border-left: 3px solid <%= ev.display_color %>;"
                           data-controller="event-popup">
                        <div data-action="click->event-popup#toggle"
                             data-event-popup-target="trigger" style="cursor: pointer;">
                          <div class="week-event-time"><%= ev.time_label %></div>
                          <div class="week-event-title"><%= ev.title.truncate(30) %></div>
                        </div>

                        <%# Popup %>
                        <div class="event-popup" hidden data-event-popup-target="popup">
                          <%= render "calendar_events/popup", event: ev %>
                        </div>
                      </div>
                    <% elsif entry[:type] == :document %>
                      <% doc = entry[:record] %>
                      <div class="week-event week-event--doc">
                        <div class="week-event-time"><%= doc.created_at.strftime("%-H:%M") %></div>
                        <%= link_to (doc.title.presence || "(untitled)").truncate(30),
                              edit_document_path(doc), class: "week-event-title" %>
                      </div>
                    <% elsif entry[:type] == :task %>
                      <% task = entry[:record] %>
                      <div class="week-event week-event--task week-event--priority-<%= task.priority %>">
                        <div class="week-event-time">
                          <% if task.due_time.present? %><%= task.due_time.strftime("%-H:%M") %><% end %>
                        </div>
                        <%= link_to task.title.truncate(30), edit_task_path(task), class: "week-event-title" %>
                      </div>
                    <% end %>
                  <% end %>
                  <% if (@week_events_by_day[day] || []).empty? %>
                    <div class="week-day-empty"></div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

      <% elsif @view_mode == "month" %>
        <%# ── MONTH VIEW ── %>
        <div class="month-view">
          <%# Navigation %>
          <div class="week-nav">
            <%= link_to calendar_path(date: (@view_date - 1.month).to_s, view: "month", filter: @filter),
                  class: "mini-month-nav-btn", "aria-label": "Previous month" do %>‹<% end %>
            <span class="week-nav-title"><%= @view_date.strftime("%B %Y") %></span>
            <%= link_to calendar_path(date: (@view_date + 1.month).to_s, view: "month", filter: @filter),
                  class: "mini-month-nav-btn", "aria-label": "Next month" do %>›<% end %>
          </div>

          <%# Day-of-week headers %>
          <div class="month-grid">
            <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |dow| %>
              <div class="month-dow"><%= dow %></div>
            <% end %>

            <%# Blank cells before month start %>
            <% ((@month_start.wday - 1) % 7).times do %>
              <div class="month-cell month-cell--empty"></div>
            <% end %>

            <%# Days of the month %>
            <% (@month_start..@month_end).each do |day| %>
              <% is_today = day == Date.today %>
              <% day_entries = @timeline[day] || [] %>
              <div class="month-cell <%= 'month-cell--today' if is_today %>">
                <%= link_to day.day, calendar_path(date: day.to_s, view: "agenda", filter: @filter),
                      class: "month-cell-num #{'month-cell-num--today' if is_today}" %>
                <div class="month-cell-events">
                  <% day_entries.first(3).each do |entry| %>
                    <% if entry[:type] == :event %>
                      <% ev = entry[:record] %>
                      <div class="month-event" style="background: <%= ev.display_color %>20; border-left: 2px solid <%= ev.display_color %>;"
                           data-controller="event-popup">
                        <span class="month-event-title"
                              data-action="click->event-popup#toggle"
                              data-event-popup-target="trigger"
                              style="cursor: pointer;"><%= ev.title.truncate(18) %></span>

                        <div class="event-popup" hidden data-event-popup-target="popup">
                          <%= render "calendar_events/popup", event: ev %>
                        </div>
                      </div>
                    <% elsif entry[:type] == :task %>
                      <% task = entry[:record] %>
                      <div class="month-event month-event--task" style="border-left: 2px solid var(--color-primary);">
                        <span class="month-event-title"><%= task.title.truncate(15) %></span>
                      </div>
                    <% else %>
                      <div class="month-event month-event--doc">
                        <span class="month-event-title"><%= (entry[:record].title.presence || "note").truncate(18) %></span>
                      </div>
                    <% end %>
                  <% end %>
                  <% if day_entries.size > 3 %>
                    <div class="month-event-more">+<%= day_entries.size - 3 %> more</div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

      <% else %>
        <%# ── AGENDA VIEW (default) ── %>
        <div class="calendar-agenda">
          <% if @timeline.empty? %>
            <div class="agenda-empty">
              <div class="agenda-empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
              </div>
              <div class="agenda-empty-text">No events in this period</div>
              <div class="agenda-empty-sub">Sync Google Calendar or create events to see them here</div>
            </div>
          <% else %>
            <% @timeline.each do |date, entries| %>
          <%
            date_id = "day-#{date}"
            is_today = date == Date.today
          %>
          <div class="agenda-day" id="<%= date_id %>" data-calendar-target="agendaDay" data-date="<%= date %>">
            <%# Day header %>
            <div class="agenda-day-header <%= 'agenda-day-header--today' if is_today %>">
              <span class="agenda-day-label">
                <span class="agenda-day-name"><%= date.strftime("%A") %></span>
                <span class="agenda-day-date"><%= date.strftime("%B %-d") %></span>
              </span>
              <% if is_today %>
                <span class="agenda-today-badge">Today</span>
              <% end %>
            </div>

            <%# Day entries %>
            <div class="agenda-entries">
              <% entries.each do |entry| %>
                <% if entry[:type] == :event %>
                  <% ev = entry[:record] %>
                  <div class="agenda-entry agenda-entry--event"
                       data-controller="event-popup">
                    <div class="agenda-entry-color-bar"
                         style="background: <%= ev.display_color %>"
                         data-action="click->event-popup#toggle"
                         data-event-popup-target="trigger"></div>
                    <div class="agenda-entry-time"
                         data-action="click->event-popup#toggle"><%= ev.time_label %></div>
                    <div class="agenda-entry-body"
                         data-action="click->event-popup#toggle">
                      <span class="agenda-entry-title"><%= ev.title %></span>
                      <% if ev.duration_label.present? && !ev.all_day? %>
                        <span class="agenda-entry-duration"><%= ev.duration_label %></span>
                      <% end %>
                      <% if ev.description.present? %>
                        <div class="agenda-entry-desc"><%= truncate(ev.description, length: 80) %></div>
                      <% end %>
                    </div>
                    <div class="agenda-entry-actions">
                      <div class="agenda-entry-source agenda-entry-source--<%= ev.source == 'google' ? 'gcal' : ev.source %>">
                        <%= ev.source == 'google' ? 'GCal' : ev.source.capitalize %>
                      </div>
                    </div>

                    <%# ── Popup detail ── %>
                    <div class="event-popup" hidden data-event-popup-target="popup">
                      <%= render "calendar_events/popup", event: ev %>
                    </div>
                  </div>
                <% elsif entry[:type] == :document %>
                  <% doc = entry[:record] %>
                  <div class="agenda-entry agenda-entry--document">
                    <div class="agenda-entry-color-bar"
                         style="background: var(--color-text-tertiary)"></div>
                    <div class="agenda-entry-time">
                      <%= doc.created_at.strftime("%-H:%M") %>
                    </div>
                    <div class="agenda-entry-body">
                      <%= link_to doc.title.presence || "(untitled)",
                            edit_document_path(doc),
                            class: "agenda-entry-title" %>
                      <% text_block = doc.blocks.find_by(block_type: "text") %>
                      <% if text_block %>
                        <div class="agenda-entry-desc">
                          <%= truncate(text_block.content_hash["text"].to_s.gsub(/[#*`>\-\[\]]+/, " ").squish, length: 80) %>
                        </div>
                      <% end %>
                    </div>
                    <div class="agenda-entry-source agenda-entry-source--inbox">
                      Inbox
                    </div>
                  </div>
                <% elsif entry[:type] == :task %>
                  <% task = entry[:record] %>
                  <div class="agenda-entry agenda-entry--task">
                    <div class="agenda-entry-color-bar"
                         style="background: var(--color-primary)"></div>
                    <%= button_to toggle_task_path(task), method: :patch,
                          class: "agenda-task-checkbox-btn" do %>
                      <span class="task-checkbox <%= 'task-checkbox--checked' if task.completed? %>">
                        <% if task.completed? %>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="width:12px;height:12px;">
                            <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                      </span>
                    <% end %>
                    <div class="agenda-entry-body">
                      <span class="agenda-entry-title <%= 'agenda-entry-title--done' if task.completed? %>">
                        <%= task.title %>
                      </span>
                      <% if task.due_time.present? %>
                        <span class="agenda-entry-duration"><%= task.due_time.strftime("%H:%M") %></span>
                      <% end %>
                      <% if task.description.present? %>
                        <div class="agenda-entry-desc"><%= truncate(task.description, length: 80) %></div>
                      <% end %>
                    </div>
                    <div class="agenda-entry-source agenda-entry-source--task">
                      Task
                    </div>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
        </div><%# .calendar-agenda %>
      <% end %><%# view_mode %>
    </section><%# .calendar-content %>

  </div><%# .calendar-layout %>
</div><%# .calendar-page %>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────────── */
  .calendar-page {
    max-width: 1100px;
    margin: 0 auto;
  }

  .calendar-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .calendar-topbar-left {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .calendar-topbar-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .topbar-btn-label { margin-left: var(--spacing-xs); }

  /* ── View mode switcher ── */
  .view-mode-switcher {
    display: flex;
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-base);
    padding: 2px;
    gap: 1px;
  }

  .view-mode-btn {
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }
  .view-mode-btn:hover {
    color: var(--color-text-primary);
  }
  .view-mode-btn--active {
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    font-weight: var(--font-semibold);
    box-shadow: var(--shadow-sm);
  }

  .calendar-heading {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin: 0;
  }

  .calendar-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--spacing-xl);
    align-items: start;
  }

  @media (max-width: 700px) {
    .calendar-layout { grid-template-columns: 1fr; }
    .calendar-sidebar { order: 2; }
    .calendar-content  { order: 1; }
  }

  /* ── Mini-month ──────────────────────────────────────────────────────────── */
  .calendar-sidebar {
    position: sticky;
    top: 1rem;
  }

  .mini-month-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-sm);
  }

  .mini-month-title {
    font-weight: var(--font-semibold);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
  }

  .mini-month-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: var(--radius-md);
    font-size: var(--text-lg);
    line-height: 1;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .mini-month-nav-btn:hover {
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
  }

  .mini-month-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--spacing-xs);
  }

  .mini-month-dow {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-tertiary);
    padding: var(--spacing-xs) 0;
  }

  .mini-month-cell {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1;
    font-size: var(--text-xs);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text-primary);
    transition: background var(--transition-fast);
    cursor: pointer;
  }

  .mini-month-cell:hover {
    background: var(--color-bg-secondary);
  }

  .mini-month-cell--empty {
    pointer-events: none;
  }

  .mini-month-cell--today {
    font-weight: var(--font-bold);
    color: var(--color-primary);
  }

  .mini-month-cell--selected {
    background: var(--color-primary) !important;
    color: var(--color-bg-primary) !important;
  }

  .mini-month-dot {
    display: block;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    margin-top: 1px;
  }

  .mini-month-cell--selected .mini-month-dot {
    background: color-mix(in srgb, var(--color-bg-primary) 70%, transparent);
  }

  /* Stats */
  .calendar-sidebar-stats {
    display: flex;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border);
  }

  .calendar-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .calendar-stat-value {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    line-height: 1;
  }

  .calendar-stat-label {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: var(--spacing-xs);
  }

  /* ── Agenda ───────────────────────────────────────────────────────────────── */
  .calendar-content {
    min-height: 400px;
  }

  .agenda-empty {
    text-align: center;
    padding: var(--spacing-2xl) var(--spacing-lg);
    color: var(--color-text-tertiary);
  }

  .agenda-empty-icon { font-size: var(--text-3xl); margin-bottom: var(--spacing-sm); }
  .agenda-empty-text { font-size: var(--text-base); font-weight: var(--font-semibold); margin-bottom: var(--spacing-xs); }
  .agenda-empty-sub  { font-size: var(--text-sm); }

  /* Day group */
  .agenda-day {
    margin-bottom: var(--spacing-xl);
    scroll-margin-top: 80px;
  }

  .agenda-day-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-border);
    margin-bottom: var(--spacing-sm);
  }

  .agenda-day-header--today {
    border-color: var(--color-primary);
  }

  .agenda-day-label {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-xs);
  }

  .agenda-day-name {
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

