<%# Calendar widget — rendered server-side in documents index sidebar.
    Data comes from @widget_today, @widget_tomorrow, @widget_week
    set in DocumentsController#index. %>

<div class="cal-widget">
  <div class="cal-widget-header">
    <span class="cal-widget-title">Upcoming</span>
    <%= link_to calendar_path, class: "cal-widget-link", title: "Open Calendar",
          "aria-label": "Open Calendar" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="cal-widget-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 2.994v2.25m10.5-2.25v2.25m-14.252 13.5V7.491a2.25 2.25 0 0 1 2.25-2.25h13.5a2.25 2.25 0 0 1 2.25 2.25v11.251m-18 0a2.25 2.25 0 0 0 2.25 2.25h13.5a2.25 2.25 0 0 0 2.25-2.25m-18 0v-7.5a2.25 2.25 0 0 1 2.25-2.25h13.5a2.25 2.25 0 0 1 2.25 2.25v7.5m-6.75-6h2.25m-9 2.25h4.5m.002-2.25h.005v.006H12v-.006Zm-.001 4.5h.006v.006h-.006v-.005Zm-2.25.001h.005v.006H9.75v-.006Zm-2.25 0h.005v.005h-.006v-.005Zm6.75-2.247h.005v.005h-.005v-.005Zm0 2.247h.006v.006h-.006v-.006Zm2.25-2.248h.006V15H16.5v-.005Z"/>
      </svg>
    <% end %>
  </div>

  <%# Today %>
  <% if @widget_today&.any? %>
    <div class="cal-widget-section">
      <div class="cal-widget-section-label">Today</div>
      <% @widget_today.each do |ev| %>
        <div class="cal-widget-event">
          <span class="cal-widget-event-dot" style="background-color: <%= ev.display_color %>;"></span>
          <div class="cal-widget-event-body">
            <div class="cal-widget-event-time"><%= ev.time_label %><% if ev.duration_label %> · <%= ev.duration_label %><% end %></div>
            <div class="cal-widget-event-title"><%= ev.title %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Tomorrow %>
  <% if @widget_tomorrow&.any? %>
    <div class="cal-widget-section">
      <div class="cal-widget-section-label">Tomorrow</div>
      <% @widget_tomorrow.each do |ev| %>
        <div class="cal-widget-event">
          <span class="cal-widget-event-dot" style="background-color: <%= ev.display_color %>;"></span>
          <div class="cal-widget-event-body">
            <div class="cal-widget-event-time"><%= ev.time_label %><% if ev.duration_label %> · <%= ev.duration_label %><% end %></div>
            <div class="cal-widget-event-title"><%= ev.title %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Rest of this week %>
  <% if @widget_week&.any? %>
    <div class="cal-widget-section">
      <div class="cal-widget-section-label">This week</div>
      <% @widget_week.each do |ev| %>
        <div class="cal-widget-event">
          <span class="cal-widget-event-dot" style="background-color: <%= ev.display_color %>;"></span>
          <div class="cal-widget-event-body">
            <div class="cal-widget-event-time"><%= ev.time_label %><% if ev.duration_label %> · <%= ev.duration_label %><% end %></div>
            <div class="cal-widget-event-title"><%= ev.title %></div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Empty state %>
  <% if @widget_today.blank? && @widget_tomorrow.blank? && @widget_week.blank? %>
    <div class="cal-widget-empty">No upcoming events</div>
  <% end %>
</div>

