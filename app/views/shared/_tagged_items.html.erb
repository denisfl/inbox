<%# Shared tagged items sections — renders documents, tasks, events for tag pages
     Locals: documents (collection), tasks (collection), calendar_events (collection) %>

<% if local_assigns[:documents].present? && documents.any? %>
  <section class="tag-section">
    <h2 class="tag-section-title">Documents (<%= documents.count %>)</h2>
    <div class="documents-grid">
      <%= render partial: "documents/card", collection: documents, as: :document %>
    </div>
  </section>
<% end %>

<% if local_assigns[:tasks].present? && tasks.any? %>
  <section class="tag-section">
    <h2 class="tag-section-title">Tasks (<%= tasks.count %>)</h2>
    <div class="task-list">
      <% tasks.each do |task| %>
        <%= render partial: "tasks/task", locals: { task: task } %>
      <% end %>
    </div>
  </section>
<% end %>

<% if local_assigns[:calendar_events].present? && calendar_events.any? %>
  <section class="tag-section">
    <h2 class="tag-section-title">Events (<%= calendar_events.count %>)</h2>
    <div class="events-list">
      <% calendar_events.each do |event| %>
        <%= render "shared/event_item", event: event %>
      <% end %>
    </div>
  </section>
<% end %>
